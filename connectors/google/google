def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except Exception:
            return {}
    return {}


def save_state(state: dict):
    DATA_ROOT.mkdir(parents=True, exist_ok=True)
    tmp = STATE_FILE.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, indent=2))
    os.replace(tmp, STATE_FILE)


# ---------------------------------------------------------------------------
# ID hashing / dedup
# ---------------------------------------------------------------------------

def _id_hash(item_id: str) -> str:
    return hashlib.sha1(item_id.encode()).hexdigest()[:16]


def _already_written(path: Path, item_id: str) -> bool:
    if not path.exists():
        return False
    return f"idhash: {_id_hash(item_id)}" in path.read_text()


def _replace_existing_entry(path: Path, item_id: str) -> bool:
    """Remove an existing entry block for item_id from the file.

    Entry blocks are delimited by '---' lines (or '\\n---' patterns).
    Returns True if an entry was found and removed.
    """
    if not path.exists():
        return False
    content = path.read_text()
    idhash = _id_hash(item_id)
    marker = f"idhash: {idhash}"
    if marker not in content:
        return False

    # Split on entry boundaries. Calendar entries start with "\n---\n".
    # Find the entry block containing our idhash and remove it.
    # Entries are separated by "\n---\n" (the leading \n---\n of each entry).
    parts = content.split("\n---\n")
    new_parts = []
    removed = False
    for part in parts:
        if marker in part and not removed:
            removed = True
            continue
        new_parts.append(part)

    if removed:
        new_content = "\n---\n".join(new_parts)
        # Clean up any leading/trailing whitespace artifacts
        path.write_text(new_content)
    return removed


# ---------------------------------------------------------------------------
# Retry decorator
# ---------------------------------------------------------------------------

# Rate-limit cooldown — shared across all API calls
_last_throttle_time = 0.0   # epoch seconds of last retryable error
_THROTTLE_COOLDOWN  = 2.0   # seconds to pause after a recent rate limit


def _is_retryable(exc: Exception) -> bool:
    global _last_throttle_time
    if isinstance(exc, HttpError):
        status = exc.resp.status
        if status in (429, 403):
            _last_throttle_time = time.time()
        return status in (401, 403, 429, 500, 502, 503, 504)
    return False


def _throttle_aware_before(retry_state):
    """Before each retry-decorated call, sleep briefly if recently throttled."""
    if time.time() - _last_throttle_time < _THROTTLE_COOLDOWN:
        time.sleep(_THROTTLE_COOLDOWN)


retry_api = tenacity.retry(
    retry=tenacity.retry_if_exception(_is_retryable),
    wait=tenacity.wait_exponential(multiplier=1, min=2, max=60),
    stop=tenacity.stop_after_attempt(6),
    before=_throttle_aware_before,
    reraise=True,
)


# ---------------------------------------------------------------------------
# Atomic file append helper
# ---------------------------------------------------------------------------

def _atomic_append(path: Path, new_content: str):
    """Atomically append new_content to path using write-to-temp + os.replace.

    Reads existing content (if any), appends new_content, writes to a temp file
    in the same directory, then does os.replace() back. This ensures that a
    crash mid-write never leaves a partial entry on disk.
    """
    path.parent.mkdir(parents=True, exist_ok=True)
    existing = ""
    if path.exists():
        existing = path.read_text(encoding="utf-8")
    fd, tmp_path = tempfile.mkstemp(dir=str(path.parent), suffix=".tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(existing + new_content)
        os.replace(tmp_path, str(path))
    except BaseException:
        # Clean up temp file on failure
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


# ---------------------------------------------------------------------------
# Gmail helpers
# ---------------------------------------------------------------------------

def _decode_body(payload: dict) -> str:
    """Extract plain text or HTML body from message payload."""
    parts = payload.get("parts", [])
    # Prefer text/plain
    for part in parts:
        if part.get("mimeType") == "text/plain":
            data = part.get("body", {}).get("data", "")
            if data:
                return base64.urlsafe_b64decode(data + "==").decode("utf-8", errors="replace")
    # Fallback to text/html, strip tags
    for part in parts:
        if part.get("mimeType") == "text/html":
            data = part.get("body", {}).get("data", "")
            if data:
                raw_html = base64.urlsafe_b64decode(data + "==").decode("utf-8", errors="replace")
                return _strip_html(raw_html)
    # Nested multipart
    for part in parts:
        sub = _decode_body(part)
        if sub:
            return sub
    # Single-part message
    data = payload.get("body", {}).get("data", "")
    if data:
        raw = base64.urlsafe_b64decode(data + "==").decode("utf-8", errors="replace")
        mime = payload.get("mimeType", "")
        if "html" in mime:
            return _strip_html(raw)
        return raw
    return ""


def _strip_html(raw: str) -> str:
    """Very simple HTML → plain text."""
    raw = re.sub(r"<style[^>]*>.*?</style>", "", raw, flags=re.DOTALL | re.IGNORECASE)
    raw = re.sub(r"<script[^>]*>.*?</script>", "", raw, flags=re.DOTALL | re.IGNORECASE)
    raw = re.sub(r"<br\s*/?>", "\n", raw, flags=re.IGNORECASE)
    raw = re.sub(r"<p\s*/?>", "\n\n", raw, flags=re.IGNORECASE)
    raw = re.sub(r"</p>", "", raw, flags=re.IGNORECASE)
    raw = re.sub(r"<[^>]+>", "", raw)
    raw = html.unescape(raw)
    raw = re.sub(r"\n{3,}", "\n\n", raw)
    return raw.strip()


def _get_header(headers: list, name: str) -> str:
    for h in headers:
        if h.get("name", "").lower() == name.lower():
            return h.get("value", "")
    return ""


def _parse_gmail_date(date_str: str) -> Optional[datetime]:
    """Parse Gmail date header to datetime."""
    import email.utils
    try:
        tup = email.utils.parsedate_tz(date_str)
        if tup:
            ts = email.utils.mktime_tz(tup)
            return datetime.fromtimestamp(ts, tz=timezone.utc)
    except Exception:
        pass
    return None


def _mail_file_path(base_path: Path, msg_date: datetime, msg_id: str) -> Path:
    """Generate individual file path for a single email message."""
    month_key = msg_date.strftime("%Y-%m")
    short_id = hashlib.sha1(msg_id.encode()).hexdigest()[:8]
    out_dir = base_path / month_key
    out_dir.mkdir(parents=True, exist_ok=True)
    filename = f"{msg_date.strftime('%Y-%m-%d-%H%M%S')}-{short_id}.md"
    return out_dir / filename


def _write_mail_md(msg: dict, base_path: Path) -> bool:
    """Write a Gmail message to an individual markdown file. Returns True if written."""
    msg_id = msg.get("id", "")
    payload = msg.get("payload", {})
    headers = payload.get("headers", [])
    snippet = msg.get("snippet", "")

    subject = _get_header(headers, "Subject") or "(no subject)"
    from_addr = _get_header(headers, "From") or ""
    to_addr = _get_header(headers, "To") or ""
    date_str = _get_header(headers, "Date") or ""
    msg_date = _parse_gmail_date(date_str)

    # Sanity check: if parsed date is >1 year in the future, the Date header
    # is garbage (seen: 2611, 2612). Fall back to internalDate.
    max_future = datetime.now(tz=timezone.utc) + timedelta(days=365)
    if msg_date and msg_date > max_future:
        msg_date = None

    if not msg_date:
        # Fall back to internalDate (milliseconds)
        internal_ms = int(msg.get("internalDate", 0))
        msg_date = datetime.fromtimestamp(internal_ms / 1000, tz=timezone.utc) if internal_ms else datetime.now(tz=timezone.utc)

    out_file = _mail_file_path(base_path, msg_date, msg_id)

    # Dedup: file exists = already written
    if out_file.exists():
        return False

    body = _decode_body(payload)
    if not body:
        body = snippet

    # Full body -- no truncation

    label_ids = msg.get("labelIds", [])
    is_read = "UNREAD" not in label_ids

    entry = (
        f"---\n"
        f"source: google-mail\n"
        f"idhash: {_id_hash(msg_id)}\n"
        f"from: {from_addr}\n"
        f"subject: {subject}\n"
        f"date: {msg_date.isoformat()}\n"
        f"to: {to_addr}\n"
        f"read: {is_read}\n"
        f"---\n\n"
        f"## {subject}\n"
        f"*From: {from_addr} | {msg_date.strftime('%Y-%m-%d %H:%M')}*\n\n"
        f"**From:** {from_addr}\n"
        f"**Date:** {msg_date.strftime('%Y-%m-%d %H:%M %Z')}\n\n"
        f"{body.strip()}\n"
    )

    # Write individual file atomically
    fd, tmp = tempfile.mkstemp(dir=out_file.parent, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(entry)
        os.replace(tmp, out_file)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise
    return True


