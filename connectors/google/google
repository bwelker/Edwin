    "https://www.googleapis.com/auth/calendar",
    "https://www.googleapis.com/auth/userinfo.email",
    "openid",
]

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

def get_credentials() -> Credentials:
    TOKEN_FILE.parent.mkdir(parents=True, exist_ok=True)
    creds = None
    if TOKEN_FILE.exists():
        creds = Credentials.from_authorized_user_file(str(TOKEN_FILE), SCOPES)
    if creds and creds.valid:
        return creds
    if creds and creds.expired and creds.refresh_token:
        try:
            creds.refresh(Request())
            _save_token(creds)
            return creds
        except Exception:
            pass
    # Fresh OAuth flow
    if not CREDS_FILE.exists():
        sys.exit(
            f"No credentials file found at {CREDS_FILE}\n"
            "Run: gog auth credentials /path/to/client_secret.json\n"
            "Or place your OAuth client JSON at the path above."
        )
    raw = json.loads(CREDS_FILE.read_text())
    client_config = {
        "installed": {
            "client_id": raw["client_id"],
            "client_secret": raw["client_secret"],
            "redirect_uris": ["http://localhost"],
            "auth_uri": "https://accounts.google.com/o/oauth2/auth",
            "token_uri": "https://oauth2.googleapis.com/token",
        }
    }
    flow = InstalledAppFlow.from_client_config(client_config, SCOPES)
    creds = flow.run_local_server(port=0, open_browser=True)
    _save_token(creds)
    return creds


def _build_service(api: str, version: str, creds: Credentials):
    """Build a Google API service with 401-safe auto-refresh.

    The google-auth-httplib2 AuthorizedHttp transport auto-refreshes tokens
    when a request receives a 401. However, it needs a proper refresh request
    object. We import google_auth_httplib2 to construct an AuthorizedHttp that
    correctly refreshes expired tokens during long syncs, then pass that as
    the http= parameter to build().
    """
    import google_auth_httplib2
    import httplib2

    # Ensure credentials are fresh before building
    if creds.expired and creds.refresh_token:
        creds.refresh(Request())
        _save_token(creds)

    # AuthorizedHttp handles automatic token refresh on 401 responses
    authed_http = google_auth_httplib2.AuthorizedHttp(
        creds, http=httplib2.Http(),
        refresh_status_codes=(401,),
    )
    return build(api, version, http=authed_http)


def _save_token(creds: Credentials):
    TOKEN_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp = TOKEN_FILE.with_suffix(".tmp")
    tmp.write_text(creds.to_json())
    os.replace(tmp, TOKEN_FILE)


