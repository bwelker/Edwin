def sync_mail(service, state: dict, since: datetime):
    """Sync Gmail. Backfill uses date-range search; incremental uses history API."""
    mail_path = DATA_ROOT / "mail"
    history_id = state.get("mail_history_id")
    last_sync = state.get("mail_last_sync")

    if history_id and last_sync and not since:
        print("  Incremental Gmail sync via history API...")
        history_id, written = _mail_incremental(service, mail_path, history_id)
        print(f"  Written: {written} new messages")
    else:
        print(f"  Backfilling Gmail since {since.strftime('%Y-%m-%d')}...")
        history_id, written = _mail_backfill(service, mail_path, since)
        print(f"  Written: {written} messages")

    state["mail_history_id"] = history_id
    state["mail_last_sync"] = datetime.now(tz=timezone.utc).isoformat()
    save_state(state)


@retry_api
def _list_messages(service, query: str, page_token: str = None) -> dict:
    kwargs = {"userId": "me", "q": query, "maxResults": 500}
    if page_token:
        kwargs["pageToken"] = page_token
    return service.users().messages().list(**kwargs).execute()


@retry_api
def _get_single_message(service, msg_id: str) -> dict:
    """Fetch a single message with retry. Used as fallback for batch failures."""
    return service.users().messages().get(userId="me", id=msg_id, format="full").execute()


def _batch_get_messages(service, msg_ids: list) -> list:
    """Batch-fetch full messages. Gmail batch = up to 100 per request.

    Tracks per-message failures in the batch callback. Failed messages are
    retried individually with the @retry_api decorator. If individual retry
    also fails, the error is logged and the failed IDs are reported.
    """
    results = []
    all_failed_ids = []
    for i in range(0, len(msg_ids), 100):
        chunk = msg_ids[i:i+100]
        batch = service.new_batch_http_request()
        chunk_results = {}
        chunk_failures = {}

        def _cb(request_id, response, exception):
            if exception is None:
                chunk_results[request_id] = response
            else:
                chunk_failures[request_id] = exception

        for mid in chunk:
            batch.add(
                service.users().messages().get(userId="me", id=mid, format="full"),
                request_id=mid,
                callback=_cb,
            )
        for attempt in tenacity.Retrying(
            retry=tenacity.retry_if_exception(_is_retryable),
            wait=tenacity.wait_exponential(multiplier=1, min=2, max=60),
            stop=tenacity.stop_after_attempt(6),
            reraise=True,
        ):
            with attempt:
                batch.execute()
        results.extend(chunk_results.values())

        # Retry failed messages individually
        for mid, exc in chunk_failures.items():
            try:
                msg = _get_single_message(service, mid)
                results.append(msg)
            except Exception as retry_exc:
                logger.error("Failed to fetch message %s after individual retry: %s", mid, retry_exc)
                all_failed_ids.append(mid)

        time.sleep(0.1)  # gentle rate limiting

    if all_failed_ids:
        logger.error("Permanently failed to fetch %d message(s): %s", len(all_failed_ids), all_failed_ids)

    return results


def _mail_backfill(service, mail_path: Path, since: datetime):
    """Backfill by month to avoid deep pagination timeouts."""
    now = datetime.now(tz=timezone.utc)
    cursor = since.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    written_total = 0
    last_history_id = None

    while cursor <= now:
        next_month = (cursor.replace(day=28) + timedelta(days=4)).replace(
            day=1, hour=0, minute=0, second=0, microsecond=0
        )
        after = cursor.strftime("%Y/%m/%d")
        before = min(next_month, now + timedelta(days=1)).strftime("%Y/%m/%d")
        query = f"after:{after} before:{before}"
        print(f"    Backfilling {cursor.strftime('%Y-%m')}...")

        msg_ids = []
        page_token = None
        while True:
            resp = _list_messages(service, query, page_token)
            msgs = resp.get("messages", [])
            msg_ids.extend(m["id"] for m in msgs)
            page_token = resp.get("nextPageToken")
            if not page_token:
                break

        if msg_ids:
            full_msgs = _batch_get_messages(service, msg_ids)
            for msg in full_msgs:
                if _write_mail_md(msg, mail_path):
                    written_total += 1
                hid = msg.get("historyId")
                if hid and (last_history_id is None or int(hid) > int(last_history_id)):
                    last_history_id = hid

        cursor = next_month

    return last_history_id, written_total


@retry_api
def _history_list(service, **kwargs) -> dict:
    """Wrapper around history().list() with retry for transient errors."""
    return service.users().history().list(**kwargs).execute()


def _mail_incremental(service, mail_path: Path, history_id: str):
    """Incremental sync via Gmail history API."""
    written = 0
    new_history_id = history_id
    page_token = None

    while True:
        try:
            kwargs = {
                "userId": "me",
                "startHistoryId": history_id,
                "historyTypes": ["messageAdded"],
                "maxResults": 500,
            }
            if page_token:
                kwargs["pageToken"] = page_token
            resp = _history_list(service, **kwargs)
        except HttpError as e:
            if e.resp.status == 404:
                # historyId expired — fall back to last 7 days
                print("  History ID expired, falling back to 7-day backfill...")
                hid, written = _mail_backfill(
                    service, mail_path, datetime.now(tz=timezone.utc) - timedelta(days=7)
                )
                return hid, written
            raise

        histories = resp.get("history", [])
        msg_ids = []
        for h in histories:
            for added in h.get("messagesAdded", []):
                msg_ids.append(added["message"]["id"])

        if msg_ids:
            full_msgs = _batch_get_messages(service, msg_ids)
            for msg in full_msgs:
                if _write_mail_md(msg, mail_path):
                    written += 1

        hid = resp.get("historyId")
        if hid:
            new_history_id = hid

        page_token = resp.get("nextPageToken")
        if not page_token:
            break

    return new_history_id, written


# ---------------------------------------------------------------------------
# Calendar sync
# ---------------------------------------------------------------------------

def sync_calendar(service, state: dict, since: Optional[datetime]):
    """Sync Google Calendar. Uses syncToken for incremental, date range for backfill.

    If since is None, attempt incremental sync using stored syncToken.
    If since is a datetime, force a full backfill from that date.
    """
    cal_path = DATA_ROOT / "calendar"
    cal_state = state.get("calendar", {})

    # Get all calendars
    cals = _list_calendars(service)
    print(f"  Found {len(cals)} calendars")

    written_total = 0
    new_cal_state = {}

    for cal in cals:
        cal_id = cal["id"]
        cal_name = cal.get("summary", cal_id)
        # Use stored syncToken only when no explicit --since was provided
        sync_token = cal_state.get(cal_id, {}).get("syncToken") if since is None else None

        if sync_token:
            print(f"    Incremental: {cal_name}")
            try:
                token, written = _cal_incremental(service, cal_path, cal_id, cal_name, sync_token)
                print(f"      Written: {written}")
            except HttpError as e:
                if e.resp.status in (410, 400):
                    print(f"      Sync token expired, full sync...")
                    fallback_since = since or (datetime.now(tz=timezone.utc) - timedelta(days=30))
                    token, written = _cal_full_sync(service, cal_path, cal_id, cal_name, fallback_since)
                    print(f"      Written: {written}")
                else:
                    raise
        else:
            # If since is None (no explicit --since and no syncToken), default to 30 days
            backfill_since = since or (datetime.now(tz=timezone.utc) - timedelta(days=30))
            print(f"    Full sync: {cal_name} since {backfill_since.strftime('%Y-%m-%d')}")
            token, written = _cal_full_sync(service, cal_path, cal_id, cal_name, backfill_since)
            print(f"      Written: {written}")
            written_total += written

        new_cal_state[cal_id] = {"syncToken": token, "summary": cal_name}

    state["calendar"] = new_cal_state
    state["calendar_last_sync"] = datetime.now(tz=timezone.utc).isoformat()
    save_state(state)
    print(f"  Calendar total written: {written_total}")


@retry_api
def _calendar_list_page(service, page_token=None) -> dict:
    kwargs = {"maxResults": 250}
    if page_token:
        kwargs["pageToken"] = page_token
    return service.calendarList().list(**kwargs).execute()


def _list_calendars(service) -> list:
    items = []
    page_token = None
    while True:
        resp = _calendar_list_page(service, page_token)
        items.extend(resp.get("items", []))
        page_token = resp.get("nextPageToken")
        if not page_token:
            break
    return items


@retry_api
def _events_list(service, **kwargs) -> dict:
    return service.events().list(**kwargs).execute()


def _cal_full_sync(service, cal_path: Path, cal_id: str, cal_name: str, since: datetime):
    written = 0
    sync_token = None
    page_token = None
    time_min = since.isoformat()

    # Cap recurring event expansion at 90 days out to prevent
    # far-future files (2032-2056+) from polluting the data.
    time_max = (datetime.now(tz=timezone.utc) + timedelta(days=90)).isoformat()

    while True:
        kwargs = {
            "calendarId": cal_id,
            "timeMin": time_min,
            "timeMax": time_max,
            "singleEvents": True,
            "maxResults": 250,
        }
        if page_token:
            kwargs["pageToken"] = page_token

        resp = _events_list(service, **kwargs)

        for event in resp.get("items", []):
            if _write_cal_md(event, cal_path, cal_name):
                written += 1

        page_token = resp.get("nextPageToken")
        if not page_token:
            sync_token = resp.get("nextSyncToken")
            break

    return sync_token, written


def _cal_incremental(service, cal_path: Path, cal_id: str, cal_name: str, sync_token: str):
    written = 0
    new_sync_token = sync_token
    page_token = None

    while True:
        kwargs = {
            "calendarId": cal_id,
            "syncToken": sync_token,
            "maxResults": 250,
            "showDeleted": True,
        }
        if page_token:
            kwargs["pageToken"] = page_token

        resp = _events_list(service, **kwargs)

        for event in resp.get("items", []):
            if event.get("status") == "cancelled":
                continue
            if _write_cal_md(event, cal_path, cal_name):
                written += 1

        page_token = resp.get("nextPageToken")
        if not page_token:
            new_sync_token = resp.get("nextSyncToken", new_sync_token)
            break

    return new_sync_token, written


def _write_cal_md(event: dict, base_path: Path, cal_name: str) -> bool:
    event_id = event.get("id", "")
    summary = event.get("summary", "(no title)")
    status = event.get("status", "confirmed")
    if status == "cancelled":
        return False

    start = event.get("start", {})
    end = event.get("end", {})
    start_str = start.get("dateTime") or start.get("date") or ""
    end_str = end.get("dateTime") or end.get("date") or ""

    # Parse start date for file placement
    try:
        if "T" in start_str:
            event_date = datetime.fromisoformat(start_str.replace("Z", "+00:00"))
        else:
            event_date = datetime.strptime(start_str[:10], "%Y-%m-%d").replace(tzinfo=timezone.utc)
    except (ValueError, TypeError):
        event_date = datetime.now(tz=timezone.utc)

    date_key = event_date.strftime("%Y-%m-%d")
    month_key = event_date.strftime("%Y-%m")
    out_dir = base_path / month_key
    out_dir.mkdir(parents=True, exist_ok=True)
    out_file = out_dir / f"{date_key}.md"

    # If the event already exists, remove the old entry so it can be replaced
    # with the updated version (P2-9 fix: don't silently drop updates).
    _replace_existing_entry(out_file, event_id)

    location = event.get("location", "")
    description = event.get("description", "")
    organizer = event.get("organizer", {}).get("email", "")
    attendees = event.get("attendees", [])
    attendee_list = ", ".join(a.get("email", "") for a in attendees[:20])
    hangout = event.get("hangoutLink", "")
    recurrence = "yes" if event.get("recurrence") else ""

    entry = (
        f"\n---\n"
        f"## {summary}\n"
        f"idhash: {_id_hash(event_id)}\n"
        f"calendar: {cal_name}\n"
        f"date: {date_key}\n"
        f"start: {start_str}\n"
        f"end: {end_str}\n"
    )
    if location:
        entry += f"location: {location}\n"
    if organizer:
        entry += f"organizer: {organizer}\n"
    if attendee_list:
        entry += f"attendees: {attendee_list}\n"
    if hangout:
        entry += f"meet: {hangout}\n"
    if recurrence:
        entry += f"recurring: {recurrence}\n"
    if description:
        desc = description.strip()
        entry += f"\n{desc}\n"

    _atomic_append(out_file, entry)
    return True


