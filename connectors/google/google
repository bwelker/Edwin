def cmd_auth(_args):
    creds = get_credentials()
    # Get user info to confirm
    service = _build_service("oauth2", "v2", creds)
    info = service.userinfo().get().execute()
    print(f"Authenticated as: {info.get('email')}")


def cmd_sync(args):
    DATA_ROOT.mkdir(parents=True, exist_ok=True)
    lock_fd = open(LOCK_FILE, "w")
    try:
        fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        print("Another sync is already running. Exiting.")
        sys.exit(1)

    try:
        creds = get_credentials()
        state = load_state()

        since_days = getattr(args, "since", 30) or 30
        since = datetime.now(tz=timezone.utc) - timedelta(days=since_days)

        sources = args.source
        if sources == "all":
            sources = ["mail", "calendar"]
        else:
            sources = [sources]

        # Handle --reset
        if getattr(args, "reset", False):
            for src in sources:
                print(f"  State cleared for: {src}")
                if src == "mail":
                    state.pop("mail_history_id", None)
                    state.pop("mail_last_sync", None)
                elif src == "calendar":
                    state.pop("calendar", None)
                    state.pop("calendar_last_sync", None)
            save_state(state)

        for src in sources:
            # Check if incremental possible (no --since, has state)
            force_since = None
            if src == "mail" and (not state.get("mail_history_id") or getattr(args, "since", None)):
                force_since = since
            elif src == "calendar" and (not state.get("calendar") or getattr(args, "since", None)):
                force_since = since

            if src == "mail":
                print("Syncing mail...")
                gmail_svc = _build_service("gmail", "v1", creds)
                sync_mail(gmail_svc, state, force_since)
            elif src == "calendar":
                print("Syncing calendar...")
                cal_svc = _build_service("calendar", "v3", creds)
                sync_calendar(cal_svc, state, force_since)
            save_state(state)

    finally:
        fcntl.flock(lock_fd, fcntl.LOCK_UN)
        lock_fd.close()
        # P3-12: Don't delete the lock file — another process may have already
        # acquired the flock between our LOCK_UN and an unlink(), which would
        # break mutual exclusion. The lock file is safe to leave on disk.


def cmd_status(_args):
    state = load_state()
    print("Google sync state:")
    print(f"  Mail history ID: {state.get('mail_history_id', 'none')}")
    print(f"  Mail last sync:  {state.get('mail_last_sync', 'never')}")
    cal_state = state.get("calendar", {})
    if cal_state:
        print(f"  Calendars: {len(cal_state)} synced")
        for cal_id, v in cal_state.items():
            print(f"    {v.get('summary', cal_id)}: token={'yes' if v.get('syncToken') else 'no'}")
    else:
        print("  Calendar: never synced")

    # Count files
    for src in ("mail", "calendar"):
        p = DATA_ROOT / src
        if p.exists():
            files = list(p.rglob("*.md"))
            total_size = sum(f.stat().st_size for f in files)
            print(f"  {src}: {len(files)} files, {total_size // 1024}KB")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="Edwin Google Connector")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("auth", help="Authenticate with Google")
    sub.add_parser("status", help="Show sync state and file counts")

    sync_p = sub.add_parser("sync", help="Sync Google data")
    sync_p.add_argument("source", choices=["all", "mail", "calendar"])
    sync_p.add_argument("--since", type=int, default=None, metavar="DAYS",
                        help="Backfill N days (forces full sync for that source)")
    sync_p.add_argument("--reset", action="store_true",
                        help="Clear state for source before syncing")

    args = parser.parse_args()

    if args.command == "auth":
        cmd_auth(args)
    elif args.command == "sync":
        cmd_sync(args)
    elif args.command == "status":
        cmd_status(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
