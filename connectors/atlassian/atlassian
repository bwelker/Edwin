# -- Config --------------------------------------------------------------------

EDWIN_HOME      = Path(os.environ.get("EDWIN_HOME", Path(__file__).resolve().parent.parent.parent))

TZ              = os.environ.get("EDWIN_TZ", "America/New_York")
DATA_DIR        = EDWIN_HOME / "data" / "atlassian"
STATE_FILE      = DATA_DIR / ".sync-state.json"
LOCK_FILE       = DATA_DIR / ".sync.lock"
ENV_FILE        = Path(__file__).resolve().parent.parent.parent / ".env"
DEFAULT_SINCE   = 30  # days back for initial sync


def _load_env():
    """Load credentials from ~/.edwin/credentials/ (preferred) or .env (fallback)."""
    env = {}
    # Load .env first as base, then overlay with credentials dir
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, val = line.partition("=")
                env[key.strip()] = val.strip()
    # Override with ~/.edwin/credentials/ files (atlassian + bitbucket)
    cred_base = Path.home() / ".edwin" / "credentials"
    for subdir in ["atlassian", "bitbucket"]:
        cred_file = cred_base / subdir / "env"
        if cred_file.exists():
            for line in cred_file.read_text().splitlines():
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    key, _, val = line.partition("=")
                    env[key.strip()] = val.strip()
    return env


# -- Lockfile ------------------------------------------------------------------

class SyncLock:
    def __init__(self):
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        self._f = None

    def __enter__(self):
        self._f = open(LOCK_FILE, "w")
        try:
            fcntl.flock(self._f, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            print("Another sync is already running — exiting.", file=sys.stderr)
            sys.exit(0)
        self._f.write(str(os.getpid()))
        self._f.flush()
        return self

    def __exit__(self, *_):
        if self._f:
            fcntl.flock(self._f, fcntl.LOCK_UN)
            self._f.close()


# -- State management ---------------------------------------------------------

def _load_state():
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except json.JSONDecodeError:
            print("  State file corrupted — starting fresh.", file=sys.stderr)
    return {}


def _save_state(state):
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    _atomic_write(STATE_FILE, json.dumps(state, indent=2))


def _atomic_write(path: Path, content: str):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=path.parent, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


# -- Markdown helpers ----------------------------------------------------------

def _id_hash(item_id: str) -> str:
    return hashlib.sha1(item_id.encode()).hexdigest()[:16]


def _sanitize_filename(name: str, max_len: int = 60) -> str:
    s = re.sub(r'[/\\:*?"<>|]', '-', name)
    s = re.sub(r'-{2,}', '-', s).strip(' .-')
    if len(s) > max_len:
        s = s[:max_len].rsplit('-', 1)[0]
    return s or "untitled"


def _try_parse_iso(s):
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None


def _format_date(dt_str):
    dt = _try_parse_iso(dt_str)
    return dt.strftime("%Y-%m-%d") if dt else ""


def _format_datetime(dt_str):
    dt = _try_parse_iso(dt_str)
    return dt.strftime("%Y-%m-%d %H:%M") if dt else ""


def _get_user(obj):
    if not obj:
        return "Unknown"
    if isinstance(obj, dict):
        return obj.get("display_name") or obj.get("displayName") or obj.get("name") or obj.get("nickname") or "Unknown"
    return str(obj)


def _strip_html(text):
    """Strip HTML tags for plain text."""
    if not text:
        return ""
    return re.sub(r'<[^>]+>', '', text).strip()


# -- HTTP client with retry ----------------------------------------------------

class APIClient:
    """HTTP client with rate limiting and retry."""

    def __init__(self, auth_header: str, base_delay: float = 0.5):
        self._auth = auth_header
        self._base_delay = base_delay
        self._last_req = 0.0
        self._backoff = 2.0

    def get(self, url: str, max_retries: int = 5):
        for attempt in range(max_retries):
            # Rate limit
            elapsed = time.time() - self._last_req
            if elapsed < self._base_delay:
                time.sleep(self._base_delay - elapsed)

            req = urllib.request.Request(url, headers={
                "Authorization": self._auth,
                "Accept": "application/json",
            })
            self._last_req = time.time()

            try:
                with urllib.request.urlopen(req, timeout=30) as resp:
                    self._backoff = 2.0
                    return json.loads(resp.read().decode())
            except urllib.error.HTTPError as e:
                if e.code == 429:
                    retry_after = e.headers.get("Retry-After")
                    wait = int(retry_after) if retry_after else min(self._backoff, 120)
                    self._backoff = min(self._backoff * 2, 120)
                    print(f"    Rate limited — waiting {wait}s", file=sys.stderr)
                    time.sleep(wait)
                    continue
                elif e.code == 404:
                    return None
                elif e.code in (500, 502, 503, 504):
                    wait = 2 ** attempt
                    print(f"    Server error {e.code} — retrying in {wait}s", file=sys.stderr)
                    time.sleep(wait)
                    continue
                else:
                    print(f"    HTTP {e.code}: {e.reason}", file=sys.stderr)
                    return None
            except (urllib.error.URLError, TimeoutError) as e:
                if attempt < max_retries - 1:
                    time.sleep(2 ** attempt)
                    continue
                print(f"    Network error: {e}", file=sys.stderr)
                return None
        return None

    def paginate(self, url: str, key: str = "values") -> list:
        results = []
        while url:
            data = self.get(url)
            if not data:
                break
            results.extend(data.get(key, data.get("results", [])))
            url = data.get("next") or data.get("_links", {}).get("next")
        return results


