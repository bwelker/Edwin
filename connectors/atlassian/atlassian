def _adf_to_markdown(node, depth=0):
    """Convert Atlassian Document Format to markdown."""
    if node is None:
        return ""
    if isinstance(node, str):
        return node
    if not isinstance(node, dict):
        return str(node)

    ntype = node.get("type", "")
    content = node.get("content", [])
    text = node.get("text", "")

    if ntype == "text":
        result = text
        for mark in node.get("marks", []):
            mt = mark.get("type", "")
            if mt == "strong":
                result = f"**{result}**"
            elif mt == "em":
                result = f"*{result}*"
            elif mt == "code":
                result = f"`{result}`"
            elif mt == "link":
                href = mark.get("attrs", {}).get("href", "")
                result = f"[{result}]({href})"
        return result
    if ntype == "paragraph":
        return "".join(_adf_to_markdown(c, depth) for c in content) + "\n\n"
    if ntype == "heading":
        level = node.get("attrs", {}).get("level", 1)
        inner = "".join(_adf_to_markdown(c, depth) for c in content)
        return "#" * level + " " + inner + "\n\n"
    if ntype == "bulletList":
        items = []
        for item in content:
            ic = "".join(_adf_to_markdown(c, depth + 1) for c in item.get("content", []))
            items.append("  " * depth + "- " + ic.strip())
        return "\n".join(items) + "\n\n"
    if ntype == "orderedList":
        items = []
        for i, item in enumerate(content, 1):
            ic = "".join(_adf_to_markdown(c, depth + 1) for c in item.get("content", []))
            items.append("  " * depth + f"{i}. " + ic.strip())
        return "\n".join(items) + "\n\n"
    if ntype == "listItem":
        return "".join(_adf_to_markdown(c, depth) for c in content)
    if ntype == "codeBlock":
        lang = node.get("attrs", {}).get("language", "")
        inner = "".join(_adf_to_markdown(c, depth) for c in content)
        return f"```{lang}\n{inner}\n```\n\n"
    if ntype == "blockquote":
        inner = "".join(_adf_to_markdown(c, depth) for c in content)
        return "\n".join("> " + line for line in inner.strip().split("\n")) + "\n\n"
    if ntype == "table":
        rows = []
        for row in content:
            cells = []
            for cell in row.get("content", []):
                ct = "".join(_adf_to_markdown(c, depth) for c in cell.get("content", []))
                cells.append(ct.strip().replace("\n", " "))
            rows.append("| " + " | ".join(cells) + " |")
        if rows:
            ncols = max(r.count("|") - 1 for r in rows)
            rows.insert(1, "| " + " | ".join(["---"] * ncols) + " |")
        return "\n".join(rows) + "\n\n"
    if ntype == "panel":
        pt = node.get("attrs", {}).get("panelType", "info")
        inner = "".join(_adf_to_markdown(c, depth) for c in content)
        return f"> **{pt.upper()}:** {inner.strip()}\n\n"
    if ntype == "inlineCard":
        url = node.get("attrs", {}).get("url", "")
        return f"[{url}]({url})"
    if ntype == "mention":
        return "@" + node.get("attrs", {}).get("text", "user")
    if ntype == "hardBreak":
        return "\n"
    if ntype == "rule":
        return "---\n\n"
    if content:
        return "".join(_adf_to_markdown(c, depth) for c in content)
    return text


def _convert_description(desc):
    if desc is None:
        return ""
    if isinstance(desc, str):
        return desc
    if isinstance(desc, dict):
        return _adf_to_markdown(desc).strip()
    return str(desc)


def sync_jira(state: dict, since_days: int = DEFAULT_SINCE, verbose: bool = False):
    env = _load_env()
    email = env.get("ATLASSIAN_EMAIL")
    token = env.get("ATLASSIAN_API_TOKEN")
    site = env.get("ATLASSIAN_SITE")
    if not all([email, token, site]):
        print("  Jira: missing ATLASSIAN_EMAIL/API_TOKEN/SITE in .env", file=sys.stderr)
        return 0

    auth = "Basic " + base64.b64encode(f"{email}:{token}".encode()).decode()
    client = APIClient(auth, base_delay=1.0)
    base_url = f"https://{site}"

    jira_state = state.get("jira", {})
    since_dt = datetime.now(timezone.utc) - timedelta(days=since_days)

    # Get projects
    print(f"  Fetching Jira projects...", file=sys.stderr)
    projects = []
    start_at = 0
    while True:
        data = client.get(f"{base_url}/rest/api/3/project/search?startAt={start_at}&maxResults=100")
        if not data or "values" not in data:
            break
        projects.extend(data["values"])
        if data.get("isLast", True) or len(data["values"]) < 100:
            break
        start_at += 100

    print(f"  Found {len(projects)} projects", file=sys.stderr)

    total_tickets = 0
    jira_dir = DATA_DIR / "jira"

    for project in projects:
        proj_key = project.get("key", "")
        proj_name = project.get("name", "")

        # Build JQL with incremental sync
        proj_state = jira_state.get("projects", {}).get(proj_key, {})
        last_sync_str = proj_state.get("lastSync")
        if last_sync_str:
            effective_since = last_sync_str[:10]  # YYYY-MM-DD
        else:
            effective_since = since_dt.strftime("%Y-%m-%d")

        jql = f'project = "{proj_key}" AND updated >= "{effective_since}" ORDER BY updated ASC'

        # Paginate with v3 search/jql (uses nextPageToken, no total count)
        proj_dir = jira_dir / proj_key
        project_count = 0
        next_token = None
        first_page = True

        while True:
            params = {"jql": jql, "maxResults": 100, "fields": "key"}
            if next_token:
                params["nextPageToken"] = next_token
            search_url = f"{base_url}/rest/api/3/search/jql?{urllib.parse.urlencode(params)}"
            result = client.get(search_url)
            if not result or "issues" not in result:
                break
            issues = result["issues"]
            if not issues:
                break

            if first_page and verbose:
                print(f"    {proj_key} ({proj_name}): fetching tickets...", file=sys.stderr)
                first_page = False

            for stub in issues:
                issue_key = stub.get("key", "")
                # Full issue details
                issue = client.get(f"{base_url}/rest/api/3/issue/{issue_key}")
                if not issue:
                    continue

                # Comments
                comments = []
                cdata = client.get(f"{base_url}/rest/api/3/issue/{issue_key}/comment?maxResults=100")
                if cdata:
                    comments = cdata.get("comments", [])

                # Changelog (status transitions)
                changelog = []
                cldata = client.get(f"{base_url}/rest/api/3/issue/{issue_key}/changelog?maxResults=100")
                if cldata:
                    changelog = cldata.get("values", [])

                content = _format_jira_issue(issue, comments, changelog)
                _atomic_write(proj_dir / f"{issue_key}.md", content)
                project_count += 1
                total_tickets += 1

                if verbose and project_count % 25 == 0:
                    print(f"      {proj_key}: {project_count}...", file=sys.stderr)

            # v3 search/jql uses nextPageToken for pagination
            if result.get("isLast", True):
                break
            next_token = result.get("nextPageToken")
            if not next_token:
                break

        # Update per-project state
        if "projects" not in jira_state:
            jira_state["projects"] = {}
        jira_state["projects"][proj_key] = {
            "lastSync": datetime.now(timezone.utc).isoformat(),
            "count": project_count,
        }

    print(f"  Jira: {total_tickets} tickets across {len(projects)} projects",
          file=sys.stderr)

    jira_state["lastSync"] = datetime.now(timezone.utc).isoformat()
    state["jira"] = jira_state
    return total_tickets


def _format_jira_issue(issue, comments, changelog):
    fields = issue.get("fields", {})
    key = issue.get("key", "UNKNOWN")
    summary = fields.get("summary", "No summary")
    status = (fields.get("status") or {}).get("name", "Unknown")
    priority = (fields.get("priority") or {}).get("name", "None")
    issue_type = (fields.get("issuetype") or {}).get("name", "Unknown")
    assignee = _get_user(fields.get("assignee"))
    reporter = _get_user(fields.get("reporter"))
    created = _format_date(fields.get("created", ""))
    updated = _format_date(fields.get("updated", ""))
    resolved = _format_date(fields.get("resolutiondate", ""))
    proj_key = (fields.get("project") or {}).get("key", "")
    description = _convert_description(fields.get("description"))
    labels = fields.get("labels", []) or []
    components = [c.get("name", "") for c in (fields.get("components") or [])]

    idhash = _id_hash(f"jira-{key}")
    lines = [
        "---",
        "source: jira",
        f"project: {proj_key}",
        f"key: {key}",
        f"idhash: {idhash}",
        f"status: {status}",
        f"assignee: {assignee}",
        f"type: {issue_type}",
        f"priority: {priority}",
        f"created: {created}",
        f"updated: {updated}",
        "---",
        "",
        f"# [{key}] {summary}",
        f"*{key}: {summary} ({status}, {assignee})*",
        "",
        "## Metadata",
        f"*{key}: {summary} ({status}, {assignee})*",
        "",
        f"- **Type:** {issue_type}",
        f"- **Status:** {status}",
        f"- **Priority:** {priority}",
        f"- **Assignee:** {assignee}",
        f"- **Reporter:** {reporter}",
        f"- **Created:** {created}",
        f"- **Updated:** {updated}",
    ]
    if resolved:
        lines.append(f"- **Resolved:** {resolved}")
    if labels:
        lines.append(f"- **Labels:** {', '.join(labels)}")
    if components:
        lines.append(f"- **Components:** {', '.join(components)}")
    lines.append("")

    lines.extend([
        "## Description",
        f"*{key}: {summary} ({status}, {assignee})*",
        "",
        description if description else "*No description provided*",
        "",
    ])

    # Status transitions
    transitions = []
    for entry in changelog:
        entry_created = entry.get("created", "")
        entry_author = _get_user(entry.get("author"))
        for item in entry.get("items", []):
            if item.get("field") == "status":
                transitions.append({
                    "date": _format_datetime(entry_created),
                    "from": item.get("fromString", ""),
                    "to": item.get("toString", ""),
                    "author": entry_author,
                })

    if transitions:
        lines.extend([
            "## Status History",
            f"*{key}: {summary} ({status}, {assignee})*",
            "",
        ])
        for t in transitions:
            lines.append(f"- **{t['date']}**: {t['from']} → {t['to']} (by {t['author']})")
        lines.append("")

    if comments:
        lines.extend([
            "## Comments",
            f"*{key}: {summary} ({status}, {assignee})*",
            "",
        ])
        for c in comments:
            c_author = _get_user(c.get("author"))
            c_date = _format_datetime(c.get("created", ""))
            c_body = _convert_description(c.get("body"))
            c_idhash = _id_hash(f"jira-comment-{c.get('id', '')}")
            lines.append(f"### {c_author} — {c_date}")
            lines.append(f"<!-- idhash: {c_idhash} -->")
            lines.append("")
            lines.append(c_body if c_body else "*Empty comment*")
            lines.append("")

    return "\n".join(lines)


