def cmd_sync(args):
    with SyncLock():
        state = _load_state()
        sources = ["bitbucket", "jira", "confluence"] if args.source == "all" else [args.source]

        if args.reset:
            for source in sources:
                state.pop(source, None)
            print(f"  State cleared for: {', '.join(sources)}", file=sys.stderr)

        fns = {"bitbucket": sync_bitbucket, "jira": sync_jira, "confluence": sync_confluence}
        total = 0
        for source in sources:
            try:
                total += fns[source](state, since_days=args.since, verbose=args.verbose)
            except Exception as e:
                print(f"  {source} sync failed: {e}", file=sys.stderr)
                if args.verbose:
                    import traceback; traceback.print_exc()
            _save_state(state)
        print(f"Sync complete — {total} total items.", file=sys.stderr)


def cmd_status(args):
    print("Atlassian Sync Status")
    print("=" * 40)
    state = {}
    if STATE_FILE.exists():
        try:
            state = json.loads(STATE_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            print("  State file corrupted")

    for source in ("bitbucket", "jira", "confluence"):
        info = state.get(source, {})
        if isinstance(info, dict) and "lastSync" in info:
            print(f"\n  {source:12s}  last sync: {info['lastSync']}")
            if source == "bitbucket" and "repos" in info:
                print(f"  {'':12s}  repos: {len(info['repos'])}")
            if source == "jira" and "projects" in info:
                total = sum(p.get("count", 0) for p in info["projects"].values())
                print(f"  {'':12s}  projects: {len(info['projects'])}, tickets: {total}")
            if source == "confluence" and "spaces" in info:
                total = sum(s.get("count", 0) for s in info["spaces"].values())
                print(f"  {'':12s}  spaces: {len(info['spaces'])}, pages: {total}")
        else:
            print(f"\n  {source:12s}  (not synced)")

    # File counts
    print()
    for subdir in ("bitbucket", "jira", "confluence"):
        d = DATA_DIR / subdir
        if d.exists():
            files = list(d.rglob("*.md"))
            print(f"  {subdir:12s}  {len(files)} files on disk")
    print()


# -- CLI -----------------------------------------------------------------------

def main():
    p   = argparse.ArgumentParser(description="Edwin Atlassian Connector")
    sub = p.add_subparsers(dest="command", required=True)

    s = sub.add_parser("sync", help="Sync to data/atlassian/")
    s.add_argument("source", choices=["all", "bitbucket", "jira", "confluence"])
    s.add_argument("--since", type=int, default=DEFAULT_SINCE,
                   help=f"Days back for initial/reset sync (default {DEFAULT_SINCE})")
    s.add_argument("--reset", action="store_true",
                   help="Clear saved state and re-fetch from --since days back")
    s.add_argument("--verbose", action="store_true")
    s.set_defaults(func=cmd_sync)

    st = sub.add_parser("status", help="Show last sync times and file counts")
    st.set_defaults(func=cmd_status)

    args = p.parse_args()
    try:
        args.func(args)
    except KeyboardInterrupt:
        print("\nInterrupted.", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        import traceback; traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
