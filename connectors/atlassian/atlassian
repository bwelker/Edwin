def sync_bitbucket(state: dict, since_days: int = DEFAULT_SINCE, verbose: bool = False):
    env = _load_env()
    username = env.get("BITBUCKET_USERNAME")
    app_pw = env.get("BITBUCKET_APP_PASSWORD")
    workspace = env.get("BITBUCKET_WORKSPACE")
    if not all([username, app_pw, workspace]):
        print("  Bitbucket: missing BITBUCKET_USERNAME/APP_PASSWORD/WORKSPACE in .env", file=sys.stderr)
        return 0

    auth = "Basic " + base64.b64encode(f"{username}:{app_pw}".encode()).decode()
    client = APIClient(auth, base_delay=0.5)
    api = "https://api.bitbucket.org/2.0"

    bb_state = state.get("bitbucket", {})
    since_dt = datetime.now(timezone.utc) - timedelta(days=since_days)

    # Get repositories
    print(f"  Fetching repositories for workspace '{workspace}'...", file=sys.stderr)
    repos = client.paginate(f"{api}/repositories/{workspace}?pagelen=100")
    print(f"  Found {len(repos)} repositories", file=sys.stderr)

    total_prs = 0
    total_commits = 0
    bb_dir = DATA_DIR / "bitbucket"

    for repo in repos:
        slug = repo.get("slug")
        if not slug:
            continue

        # Per-repo incremental: check last sync
        repo_state = bb_state.get("repos", {}).get(slug, {})
        last_sync_str = repo_state.get("lastSync")
        if last_sync_str:
            effective_since = _try_parse_iso(last_sync_str) or since_dt
        else:
            effective_since = since_dt

        # --- PRs ---
        pr_url = f"{api}/repositories/{workspace}/{slug}/pullrequests?state=all&pagelen=50"
        prs = []
        page_url = pr_url
        while page_url:
            data = client.get(page_url)
            if not data:
                break
            for pr in data.get("values", []):
                updated = _try_parse_iso(pr.get("updated_on") or pr.get("created_on"))
                if updated and updated < effective_since:
                    page_url = None
                    break
                prs.append(pr)
            else:
                page_url = data.get("next")
                continue
            break

        if prs and verbose:
            print(f"    {slug}: {len(prs)} PRs", file=sys.stderr)

        pr_dir = bb_dir / slug / "pulls"
        for pr in prs:
            pr_id = pr.get("id")
            # Get comments and activity
            comments = client.paginate(
                f"{api}/repositories/{workspace}/{slug}/pullrequests/{pr_id}/comments?pagelen=100")
            # Activity endpoint doesn't support pagelen param
            activity_data = client.get(
                f"{api}/repositories/{workspace}/{slug}/pullrequests/{pr_id}/activity")
            activity = activity_data.get("values", []) if activity_data else []

            content = _format_bitbucket_pr(pr, comments, activity, workspace, slug)
            filepath = pr_dir / f"PR-{pr_id}.md"
            _atomic_write(filepath, content)
            total_prs += 1

        # --- Commits ---
        commits = []
        commit_url = f"{api}/repositories/{workspace}/{slug}/commits?pagelen=100"
        page_url = commit_url
        while page_url:
            data = client.get(page_url)
            if not data:
                break
            for commit in data.get("values", []):
                commit_dt = _try_parse_iso(commit.get("date"))
                if commit_dt and commit_dt < effective_since:
                    page_url = None
                    break
                commits.append(commit)
            else:
                page_url = data.get("next")
                continue
            break

        if commits:
            # Group by month
            by_month = defaultdict(list)
            for commit in commits:
                dt = _try_parse_iso(commit.get("date"))
                if dt:
                    by_month[dt.strftime("%Y-%m")].append(commit)

            commit_dir = bb_dir / slug / "commits"
            for month, month_commits in by_month.items():
                content = _format_bitbucket_commits(month_commits, workspace, slug, month)
                _atomic_write(commit_dir / f"{month}.md", content)
                total_commits += len(month_commits)

            if verbose:
                print(f"    {slug}: {len(commits)} commits", file=sys.stderr)

        # Update per-repo state
        if "repos" not in bb_state:
            bb_state["repos"] = {}
        bb_state["repos"][slug] = {"lastSync": datetime.now(timezone.utc).isoformat()}

    print(f"  Bitbucket: {total_prs} PRs, {total_commits} commits across {len(repos)} repos",
          file=sys.stderr)

    bb_state["lastSync"] = datetime.now(timezone.utc).isoformat()
    state["bitbucket"] = bb_state
    return total_prs + total_commits


def _format_bitbucket_pr(pr, comments, activity, workspace, slug):
    pr_id = pr.get("id")
    title = pr.get("title", "Untitled")
    author = _get_user(pr.get("author"))
    pr_state = pr.get("state", "UNKNOWN")
    created = pr.get("created_on", "")
    updated = pr.get("updated_on", "")
    description = pr.get("description", "") or ""

    reviewers = [_get_user(r) for r in pr.get("reviewers", [])]
    approvals = [_get_user(p.get("user")) for p in pr.get("participants", []) if p.get("approved")]

    idhash = _id_hash(f"bitbucket-pr-{workspace}-{slug}-{pr_id}")
    lines = [
        "---",
        "source: bitbucket",
        f"workspace: {workspace}",
        f"repo: {slug}",
        "type: pull_request",
        f"pr_id: {pr_id}",
        f"idhash: {idhash}",
        f"state: {pr_state}",
        f"author: {author}",
        f"created: {_format_date(created)}",
        f"updated: {_format_date(updated)}",
        "---",
        "",
        f"# PR #{pr_id}: {title}",
        f"*PR #{pr_id} in {slug} ({workspace}, {pr_state}, {_format_date(created)})*",
        "",
        f"**Author:** {author}",
        f"**State:** {pr_state}",
        f"**Created:** {_format_datetime(created)}",
        f"**Updated:** {_format_datetime(updated)}",
    ]
    if reviewers:
        lines.append(f"**Reviewers:** {', '.join(reviewers)}")
    if approvals:
        lines.append(f"**Approved by:** {', '.join(approvals)}")
    lines.append("")

    if description.strip():
        lines.extend(["## Description", f"*PR #{pr_id}: {title} ({slug}, {_format_date(created)})*", "", description.strip(), ""])

    if comments:
        lines.extend(["## Comments", f"*PR #{pr_id}: {title} ({slug}, {_format_date(created)})*", ""])
        for c in comments:
            c_author = _get_user(c.get("user"))
            c_date = _format_datetime(c.get("created_on"))
            c_text = c.get("content", {}).get("raw", "") or ""
            inline = c.get("inline")
            if inline:
                path = inline.get("path", "")
                line_num = inline.get("to") or inline.get("from", "")
                lines.append(f"### Inline: {path}:{line_num}")
            c_idhash = _id_hash(f"bb-comment-{c.get('id', '')}")
            lines.append(f"<!-- idhash: {c_idhash} -->")
            lines.append(f"**{c_author}** ({c_date}):")
            lines.append(f"> {c_text.replace(chr(10), chr(10) + '> ')}")
            lines.append("")

    approval_events = [a for a in activity if a.get("approval")]
    if approval_events:
        lines.extend(["## Approvals", f"*PR #{pr_id}: {title} ({slug}, {_format_date(created)})*", ""])
        for event in approval_events:
            approval = event.get("approval", {})
            lines.append(f"- **{_get_user(approval.get('user'))}** approved on {_format_datetime(approval.get('date'))}")
        lines.append("")

    return "\n".join(lines)


def _format_bitbucket_commits(commits, workspace, slug, month):
    idhash = _id_hash(f"bitbucket-commits-{workspace}-{slug}-{month}")
    lines = [
        "---",
        "source: bitbucket",
        f"workspace: {workspace}",
        f"repo: {slug}",
        "type: commits",
        f"year_month: {month}",
        f"idhash: {idhash}",
        f"commit_count: {len(commits)}",
        "---",
        "",
        f"# Commits — {slug} — {month}",
        "",
    ]
    for commit in commits:
        c_hash = commit.get("hash", "")[:12]
        message = (commit.get("message", "") or "").strip()
        author = _get_user(commit.get("author", {}).get("user"))
        date = _format_datetime(commit.get("date"))
        first_line = message.split("\n")[0] if message else "No message"

        c_idhash = _id_hash(f"bb-commit-{commit.get('hash', '')}")
        lines.append(f"## `{c_hash}` — {first_line}")
        lines.append(f"*Commit in {slug} ({workspace}, {date})*")
        lines.append("")
        lines.append(f"<!-- idhash: {c_idhash} -->")
        lines.append(f"**Author:** {author}  ")
        lines.append(f"**Date:** {date}")
        if "\n" in message:
            lines.extend(["", f"```", message, "```"])
        lines.append("")

    return "\n".join(lines)


