class _ConfluenceHTMLParser(html.parser.HTMLParser):
    """Parse Confluence storage format (XHTML) to markdown."""

    def __init__(self):
        super().__init__()
        self.output = []
        self.current_text = []
        self.in_table = False
        self.table_rows = []
        self.current_row = []
        self.current_cell = []
        self.in_code = False
        self.in_pre = False
        self.list_stack = []
        self.in_link = False
        self.link_href = ""
        self.link_text = []
        self.heading_level = 0
        self.in_strong = False
        self.in_em = False
        self.skip_content = False

    def handle_starttag(self, tag, attrs):
        attrs_dict = dict(attrs)
        if tag in ("script", "style", "ac:parameter"):
            self.skip_content = True
            return
        if tag in ("h1", "h2", "h3", "h4", "h5", "h6"):
            self._flush()
            self.heading_level = int(tag[1])
        elif tag == "p":
            self._flush()
        elif tag == "br":
            self.current_text.append("\n")
        elif tag in ("strong", "b"):
            self.in_strong = True
        elif tag in ("em", "i"):
            self.in_em = True
        elif tag == "a":
            self.in_link = True
            self.link_href = attrs_dict.get("href", "")
            self.link_text = []
        elif tag == "code":
            self.in_code = True
            self.current_text.append("`")
        elif tag == "pre":
            self._flush()
            self.in_pre = True
            self.output.append("\n```\n")
        elif tag in ("ul", "ol"):
            self._flush()
            self.list_stack.append({"type": tag, "count": 0})
        elif tag == "li":
            self._flush()
            if self.list_stack:
                indent = "  " * (len(self.list_stack) - 1)
                info = self.list_stack[-1]
                if info["type"] == "ol":
                    info["count"] += 1
                    self.output.append(f"{indent}{info['count']}. ")
                else:
                    self.output.append(f"{indent}- ")
        elif tag == "table":
            self._flush()
            self.in_table = True
            self.table_rows = []
        elif tag == "tr":
            self.current_row = []
        elif tag in ("td", "th"):
            self.current_cell = []
        elif tag == "blockquote":
            self._flush()
            self.output.append("> ")
        elif tag == "hr":
            self._flush()
            self.output.append("\n---\n")
        elif tag == "ac:structured-macro":
            if attrs_dict.get("ac:name", "") in ("code", "noformat"):
                self._flush()
                self.in_pre = True
                self.output.append("\n```\n")

    def handle_endtag(self, tag):
        if tag in ("script", "style", "ac:parameter"):
            self.skip_content = False
            return
        if tag in ("h1", "h2", "h3", "h4", "h5", "h6"):
            text = "".join(self.current_text).strip()
            self.current_text = []
            if text:
                self.output.append(f"\n{'#' * self.heading_level} {text}\n\n")
            self.heading_level = 0
        elif tag == "p":
            self._flush()
            self.output.append("\n\n")
        elif tag in ("strong", "b"):
            self.in_strong = False
        elif tag in ("em", "i"):
            self.in_em = False
        elif tag == "a":
            if self.in_link:
                text = "".join(self.link_text).strip()
                if self.link_href and text:
                    self.current_text.append(f"[{text}]({self.link_href})")
                elif text:
                    self.current_text.append(text)
                self.in_link = False
                self.link_text = []
        elif tag == "code":
            self.current_text.append("`")
            self.in_code = False
        elif tag == "pre":
            self._flush()
            self.output.append("\n```\n\n")
            self.in_pre = False
        elif tag in ("ul", "ol"):
            self._flush()
            if self.list_stack:
                self.list_stack.pop()
            self.output.append("\n")
        elif tag == "li":
            self._flush()
            self.output.append("\n")
        elif tag in ("td", "th"):
            self.current_row.append("".join(self.current_cell).strip())
        elif tag == "tr":
            if self.current_row:
                self.table_rows.append(self.current_row)
        elif tag == "table":
            self._render_table()
            self.in_table = False
        elif tag == "ac:structured-macro":
            if self.in_pre:
                self._flush()
                self.output.append("\n```\n\n")
                self.in_pre = False

    def handle_data(self, data):
        if self.skip_content:
            return
        if self.in_link:
            self.link_text.append(data)
        elif self.in_table and self.current_row is not None:
            self.current_cell.append(data)
        else:
            text = data
            if self.in_strong:
                text = f"**{data}**"
            if self.in_em:
                text = f"*{data}*"
            self.current_text.append(text)

    def _flush(self):
        if self.current_text:
            self.output.append(re.sub(r'\s+', ' ', "".join(self.current_text)))
            self.current_text = []

    def _render_table(self):
        if not self.table_rows:
            return
        ncols = max(len(r) for r in self.table_rows)
        self.output.append("\n")
        for i, row in enumerate(self.table_rows):
            while len(row) < ncols:
                row.append("")
            self.output.append("| " + " | ".join(row) + " |\n")
            if i == 0:
                self.output.append("| " + " | ".join(["---"] * ncols) + " |\n")
        self.output.append("\n")

    def get_markdown(self):
        self._flush()
        text = "".join(self.output)
        return re.sub(r'\n{3,}', '\n\n', text).strip()


def _storage_to_markdown(storage):
    if not storage:
        return ""
    storage = html.unescape(storage)
    parser = _ConfluenceHTMLParser()
    try:
        parser.feed(storage)
        return parser.get_markdown()
    except Exception:
        return re.sub(r'<[^>]+>', ' ', storage).strip()


def sync_confluence(state: dict, since_days: int = DEFAULT_SINCE, verbose: bool = False):
    env = _load_env()
    email = env.get("ATLASSIAN_EMAIL")
    token = env.get("ATLASSIAN_API_TOKEN")
    site = env.get("ATLASSIAN_SITE")
    if not all([email, token, site]):
        print("  Confluence: missing ATLASSIAN_EMAIL/API_TOKEN/SITE in .env", file=sys.stderr)
        return 0

    auth = "Basic " + base64.b64encode(f"{email}:{token}".encode()).decode()
    client = APIClient(auth, base_delay=1.0)
    api_v2 = f"https://{site}/wiki/api/v2"
    api_v1 = f"https://{site}/wiki/rest/api"

    conf_state = state.get("confluence", {})
    since_dt = datetime.now(timezone.utc) - timedelta(days=since_days)

    # Get spaces
    print(f"  Fetching Confluence spaces...", file=sys.stderr)
    spaces = []
    url = f"{api_v2}/spaces?limit=250"
    while url:
        data = client.get(url)
        if not data:
            break
        for space in data.get("results", []):
            # Skip personal spaces
            if space.get("key", "").startswith("~"):
                continue
            spaces.append(space)
        url = data.get("_links", {}).get("next")
        if url and not url.startswith("http"):
            url = f"https://{site}/wiki/api/v2{url}" if "/api/v2" not in url else f"https://{site}{url}"

    print(f"  Found {len(spaces)} spaces (excluding personal)", file=sys.stderr)

    total_pages = 0
    conf_dir = DATA_DIR / "confluence"

    for space in spaces:
        space_id = space.get("id")
        space_key = space.get("key")
        space_name = space.get("name", space_key)

        # Per-space incremental
        space_state = conf_state.get("spaces", {}).get(space_key, {})
        last_sync_str = space_state.get("lastSync")
        cutoff = _try_parse_iso(last_sync_str) or since_dt

        # Get pages
        pages = []
        page_url = f"{api_v2}/spaces/{space_id}/pages?limit=250&body-format=storage"
        while page_url:
            data = client.get(page_url)
            if not data:
                break
            for page in data.get("results", []):
                updated_str = page.get("version", {}).get("createdAt", "")
                updated = _try_parse_iso(updated_str)
                if updated and updated < cutoff:
                    continue
                pages.append(page)
            links = data.get("_links", {})
            page_url = links.get("next")
            if page_url and not page_url.startswith("http"):
                page_url = f"https://{site}{page_url}"

        # Get blog posts
        blogs = []
        blog_url = f"{api_v2}/spaces/{space_id}/blogposts?limit=250&body-format=storage"
        while blog_url:
            data = client.get(blog_url)
            if not data:
                break
            for post in data.get("results", []):
                updated_str = post.get("version", {}).get("createdAt", "")
                updated = _try_parse_iso(updated_str)
                if updated and updated < cutoff:
                    continue
                blogs.append(post)
            links = data.get("_links", {})
            blog_url = links.get("next")
            if blog_url and not blog_url.startswith("http"):
                blog_url = f"https://{site}{blog_url}"

        all_items = [(p, "page") for p in pages] + [(b, "blogpost") for b in blogs]
        if not all_items:
            continue

        if verbose:
            print(f"    {space_key} ({space_name}): {len(pages)} pages, {len(blogs)} blogs", file=sys.stderr)

        space_dir = conf_dir / space_key
        for item, item_type in all_items:
            page_id = item.get("id")
            title = item.get("title", "Untitled")

            # Get full body
            body_storage = item.get("body", {}).get("storage", {}).get("value", "")
            if not body_storage:
                detail = client.get(f"{api_v2}/pages/{page_id}?body-format=storage")
                if detail:
                    body_storage = detail.get("body", {}).get("storage", {}).get("value", "")

            body_md = _storage_to_markdown(body_storage)

            # Get labels
            labels_data = client.get(f"{api_v2}/pages/{page_id}/labels")
            labels = [l.get("name", "") for l in (labels_data or {}).get("results", [])]

            # Get comments via v1 API
            comments = []
            cdata = client.get(f"{api_v1}/content/{page_id}/child/comment?expand=body.storage,version", )
            if cdata:
                for c in cdata.get("results", []):
                    comments.append({
                        "author": c.get("version", {}).get("by", {}).get("displayName", "Unknown"),
                        "created": c.get("version", {}).get("when", ""),
                        "body": c.get("body", {}).get("storage", {}).get("value", ""),
                    })

            version = item.get("version", {})
            slug = _sanitize_filename(title)
            idhash = _id_hash(f"confluence-{space_key}-{page_id}")

            lines = [
                "---",
                "source: confluence",
                f"type: {item_type}",
                f"space: {space_key}",
                f"space_name: {space_name}",
                f"page_id: {page_id}",
                f"idhash: {idhash}",
                f"title: {title}",
                f"updated: {version.get('createdAt', '')}",
                f"version: {version.get('number', 1)}",
            ]
            if labels:
                lines.append(f"labels: {', '.join(labels)}")
            lines.extend([
                "---",
                "",
                f"# {title}",
                f"*{title} ({space_key}, updated {_format_date(version.get('createdAt', ''))})*",
                "",
                body_md,
            ])

            if comments:
                lines.extend(["", "---", "", "## Comments",
                              f"*{title} ({space_key})*", ""])
                for c in comments:
                    c_body = _storage_to_markdown(c.get("body", ""))
                    c_idhash = _id_hash(f"conf-comment-{page_id}-{c.get('created', '')}")
                    lines.append(f"<!-- idhash: {c_idhash} -->")
                    lines.append(f"**{c['author']}** ({_format_datetime(c['created'])}):")
                    lines.append("")
                    lines.append(c_body)
                    lines.append("")

            content = "\n".join(lines)
            _atomic_write(space_dir / f"{page_id}-{slug}.md", content)
            total_pages += 1

        # Update per-space state
        if "spaces" not in conf_state:
            conf_state["spaces"] = {}
        conf_state["spaces"][space_key] = {
            "lastSync": datetime.now(timezone.utc).isoformat(),
            "count": len(all_items),
        }

    print(f"  Confluence: {total_pages} pages across {len(spaces)} spaces",
          file=sys.stderr)

    conf_state["lastSync"] = datetime.now(timezone.utc).isoformat()
    state["confluence"] = conf_state
    return total_pages


