#!/usr/bin/env python3
"""
Edwin Atlassian Connector — Bitbucket + Jira + Confluence archiver

Modes:
  sync <source>   — incremental extraction to data/atlassian/
  status          — show last sync times

Sources: bitbucket, jira, confluence, all

APIs:
  Bitbucket: REST v2 (Basic auth with app password)
  Jira:      REST v3 (Basic auth with API token)
  Confluence: REST v2 (Basic auth with API token)
"""

