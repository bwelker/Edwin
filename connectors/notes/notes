#!/usr/bin/env python3
"""
Edwin Apple Notes Connector — macOS NoteStore database archiver

Modes:
  sync <source>   — incremental extraction to data/notes/
  status          — show last sync times

Sources: notes, all
  "all" = notes (only source for now)

Database: ~/Library/Group Containers/group.com.apple.notes/NoteStore.sqlite (read-only)
  Note body is gzip-compressed protobuf; we extract text via regex after decompression.
"""

import os
import sys
import json
import argparse
import re
import gzip
import sqlite3
import fcntl
import tempfile
import hashlib
from datetime import datetime, timedelta, timezone
from pathlib import Path
import pytz


# -- Config --------------------------------------------------------------------

EDWIN_HOME      = Path(os.environ.get("EDWIN_HOME", Path(__file__).resolve().parent.parent.parent))
DB_PATH         = Path.home() / "Library" / "Group Containers" / "group.com.apple.notes" / "NoteStore.sqlite"
TZ              = os.environ.get("EDWIN_TZ", "America/New_York")
DATA_DIR        = EDWIN_HOME / "data" / "notes"
STATE_FILE      = DATA_DIR / ".sync-state.json"
LOCK_FILE       = DATA_DIR / ".sync.lock"
DEFAULT_SINCE   = 30  # days back for initial sync

COREDATA_EPOCH_OFFSET = 978307200

# Skip notes containing credentials/secrets
SKIP_PATTERNS = re.compile(
    r'access.?key|api.?secret|\.env\b|AKIA[A-Z0-9]|password.{0,5}[:=]|'
    r'api.?token.{0,5}[:=]|service.?token|AWS.?Secret|cloudflare.?key|'
    r'sk-ant-api|sk-[a-zA-Z0-9]{20,}',
    re.IGNORECASE
)


# -- Lockfile ------------------------------------------------------------------

class SyncLock:
    def __init__(self):
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        self._f = None

    def __enter__(self):
        self._f = open(LOCK_FILE, "w")
        try:
            fcntl.flock(self._f, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            print("Another sync is already running — exiting.", file=sys.stderr)
            sys.exit(0)
        self._f.write(str(os.getpid()))
        self._f.flush()
        return self

    def __exit__(self, *_):
        if self._f:
            fcntl.flock(self._f, fcntl.LOCK_UN)
            self._f.close()


# -- State management ---------------------------------------------------------

def _load_state():
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except json.JSONDecodeError:
            print("  State file corrupted — starting fresh.", file=sys.stderr)
    return {}


def _save_state(state):
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    _atomic_write(STATE_FILE, json.dumps(state, indent=2))


def _atomic_write(path: Path, content: str):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=path.parent, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


# -- Markdown helpers ----------------------------------------------------------

def _id_hash(item_id: str) -> str:
    return hashlib.sha1(item_id.encode()).hexdigest()[:16]


def _sanitize_filename(name: str, max_len: int = 60) -> str:
    s = re.sub(r'[/\\:*?"<>|]', '-', name)
    s = re.sub(r'-{2,}', '-', s).strip(' .-')
    if len(s) > max_len:
        s = s[:max_len].rsplit('-', 1)[0]
    return s or "untitled"


def _coredata_to_datetime(ts, tz):
    if ts is None:
        return None
    unix_ts = ts + COREDATA_EPOCH_OFFSET
    return datetime.fromtimestamp(unix_ts, tz=tz)


# -- Note body extraction ------------------------------------------------------

def _extract_note_text(zdata):
    """Extract plaintext from Apple Notes gzip+protobuf ZDATA blob."""
    if not zdata:
        return ""
    try:
        decompressed = gzip.decompress(zdata)
    except Exception:
        return ""
    # Note text is stored as UTF-8 within the protobuf binary.
    # After decompression, extract the largest contiguous text block.
    text = decompressed.decode("utf-8", errors="ignore")
    blocks = re.findall(r'(?:[\x20-\x7e\n\r\t]){10,}', text)
    if not blocks:
        return ""
    # The first large block is typically the note content
    return blocks[0].strip()


# -- Database helpers ----------------------------------------------------------

def _connect_db():
    if not DB_PATH.exists():
        print(f"NoteStore database not found at {DB_PATH}", file=sys.stderr)
        print("Ensure Full Disk Access is enabled.", file=sys.stderr)
        sys.exit(1)
    uri = f"file:{DB_PATH}?mode=ro"
    conn = sqlite3.connect(uri, uri=True)
    conn.row_factory = sqlite3.Row
    return conn


# -- Sync ----------------------------------------------------------------------

NOTES_QUERY = """
SELECT
    n.Z_PK as note_id,
    n.ZTITLE1 as title,
    n.ZSNIPPET as snippet,
    n.ZCREATIONDATE3 as created_ts,
    n.ZMODIFICATIONDATE1 as modified_ts,
    n.ZIDENTIFIER as identifier,
    f.ZTITLE2 as folder,
    nd.ZDATA as body_data
FROM ZICCLOUDSYNCINGOBJECT n
LEFT JOIN ZICCLOUDSYNCINGOBJECT f ON n.ZFOLDER = f.Z_PK
LEFT JOIN ZICNOTEDATA nd ON nd.ZNOTE = n.Z_PK
WHERE n.ZTITLE1 IS NOT NULL
  AND (n.ZMARKEDFORDELETION IS NULL OR n.ZMARKEDFORDELETION != 1)
  AND n.ZMODIFICATIONDATE1 >= ?
ORDER BY n.ZMODIFICATIONDATE1 ASC
"""


def sync_notes(state: dict, since_days: int = DEFAULT_SINCE, verbose: bool = False):
    """Sync notes from Apple Notes database."""
    tz = pytz.timezone(TZ)

    notes_state = state.get("notes", {})
    last_sync_coredata = notes_state.get("lastSyncCoreData")
    if last_sync_coredata is not None:
        cutoff = float(last_sync_coredata)
        print(f"  Syncing notes since last sync...", file=sys.stderr)
    else:
        since_dt = datetime.now(timezone.utc) - timedelta(days=since_days)
        cutoff = since_dt.timestamp() - COREDATA_EPOCH_OFFSET
        print(f"  Backfilling notes {since_days} days...", file=sys.stderr)

    conn = _connect_db()
    try:
        rows = conn.execute(NOTES_QUERY, (cutoff,)).fetchall()
        if verbose:
            print(f"  Found {len(rows)} notes in range", file=sys.stderr)

        written = 0
        skipped_creds = 0
        max_ts = cutoff
        notes_dir = DATA_DIR / "notes"

        for row in rows:
            note_id = row["note_id"]
            title = row["title"] or "Untitled"
            folder = row["folder"] or "Notes"
            created_dt = _coredata_to_datetime(row["created_ts"], tz)
            modified_dt = _coredata_to_datetime(row["modified_ts"], tz)
            identifier = row["identifier"] or str(note_id)

            # Extract body text
            body = _extract_note_text(row["body_data"])
            if not body:
                body = row["snippet"] or ""

            # Skip notes with credential patterns
            full_text = f"{title}\n{body}"
            if SKIP_PATTERNS.search(full_text):
                skipped_creds += 1
                if verbose:
                    print(f"    Skipped (credentials): {title[:50]}", file=sys.stderr)
                continue

            # Build markdown
            created_str = created_dt.strftime("%Y-%m-%d %H:%M") if created_dt else ""
            modified_str = modified_dt.strftime("%Y-%m-%d %H:%M") if modified_dt else ""
            idhash = _id_hash(f"notes-{identifier}")

            lines = [
                "---",
                "source: apple-notes",
                f"note_id: {note_id}",
                f"idhash: {idhash}",
                f"folder: {folder}",
                f"created: {created_str}",
                f"modified: {modified_str}",
                "---",
                "",
                f"# {title}",
                f"*{title} ({folder}, modified {modified_str})*",
                "",
                body,
                "",
            ]

            content = "\n".join(lines)
            filename = _sanitize_filename(f"{note_id}-{title}")
            filepath = notes_dir / f"{filename}.md"
            _atomic_write(filepath, content)
            written += 1

            if row["modified_ts"] and row["modified_ts"] > max_ts:
                max_ts = row["modified_ts"]

            if verbose and written % 50 == 0:
                print(f"    {written} notes written...", file=sys.stderr)

        print(f"  Notes: {written} written, {skipped_creds} skipped (credentials)",
              file=sys.stderr)

        max_dt = _coredata_to_datetime(max_ts, pytz.utc)
        state["notes"] = {
            "lastSyncCoreData": str(max_ts),
            "lastSync": max_dt.isoformat() if max_dt else "",
        }

    finally:
        conn.close()

    return written


# -- Commands ------------------------------------------------------------------

def cmd_sync(args):
    if not DB_PATH.exists():
        print(f"NoteStore database not found at {DB_PATH}", file=sys.stderr)
        sys.exit(1)

    with SyncLock():
        state = _load_state()
        sources = ["notes"] if args.source == "all" else [args.source]

        if args.reset:
            for source in sources:
                state.pop(source, None)
            print(f"  State cleared for: {', '.join(sources)}", file=sys.stderr)

        fns = {"notes": sync_notes}
        total = 0
        for source in sources:
            try:
                total += fns[source](state, since_days=args.since, verbose=args.verbose)
            except Exception as e:
                print(f"  {source} sync failed: {e}", file=sys.stderr)
                if args.verbose:
                    import traceback; traceback.print_exc()
            _save_state(state)
        print(f"Sync complete — {total} total items.", file=sys.stderr)


def cmd_status(args):
    print("Apple Notes Sync Status")
    print("=" * 40)
    state = {}
    if STATE_FILE.exists():
        try:
            state = json.loads(STATE_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            print("  State file corrupted")

    for source in ("notes",):
        info = state.get(source, {})
        if isinstance(info, dict) and "lastSync" in info:
            print(f"  {source:12s}  last sync: {info['lastSync']}")
        else:
            print(f"  {source:12s}  (not synced)")

    print()
    notes_dir = DATA_DIR / "notes"
    if notes_dir.exists():
        files = list(notes_dir.glob("*.md"))
        print(f"  note files     {len(files)} on disk")
    print()

    if DB_PATH.exists():
        try:
            conn = _connect_db()
            total = conn.execute(
                "SELECT COUNT(*) FROM ZICCLOUDSYNCINGOBJECT WHERE ZTITLE1 IS NOT NULL AND (ZMARKEDFORDELETION IS NULL OR ZMARKEDFORDELETION != 1)"
            ).fetchone()[0]
            conn.close()
            print(f"  Database: {total:,} notes")
        except Exception as e:
            print(f"  Database: error reading ({e})")
    else:
        print(f"  Database: not found at {DB_PATH}")
    print()


# -- CLI -----------------------------------------------------------------------

def main():
    p   = argparse.ArgumentParser(description="Edwin Apple Notes Connector")
    sub = p.add_subparsers(dest="command", required=True)

    s = sub.add_parser("sync", help="Sync Apple Notes to data/notes/")
    s.add_argument("source", choices=["all", "notes"])
    s.add_argument("--since", type=int, default=DEFAULT_SINCE,
                   help=f"Days back for initial/reset sync (default {DEFAULT_SINCE})")
    s.add_argument("--reset", action="store_true")
    s.add_argument("--verbose", action="store_true")
    s.set_defaults(func=cmd_sync)

    st = sub.add_parser("status", help="Show last sync times and file counts")
    st.set_defaults(func=cmd_status)

    args = p.parse_args()
    try:
        args.func(args)
    except KeyboardInterrupt:
        print("\nInterrupted.", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        import traceback; traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
