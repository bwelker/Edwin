#!/usr/bin/env python3
"""
Edwin Screentime Connector — macOS KnowledgeC database archiver

Modes:
  sync <source>   — incremental extraction to data/screentime/
  status          — show last sync times

Sources: usage, all
  "all" = usage (only source for now)

Database: ~/Library/Application Support/Knowledge/knowledgeC.db (read-only)
"""

import os
import sys
import json
import argparse
import fcntl
import tempfile
import hashlib
from datetime import datetime, timedelta, timezone
from pathlib import Path
from collections import defaultdict
import pytz


# -- Config --------------------------------------------------------------------

DB_PATH         = Path.home() / "Library" / "Application Support" / "Knowledge" / "knowledgeC.db"
EDWIN_HOME      = Path(os.environ.get("EDWIN_HOME", Path(__file__).resolve().parent.parent.parent))
TZ              = os.environ.get("EDWIN_TZ", "America/New_York")
DATA_DIR        = EDWIN_HOME / "data" / "screentime"
STATE_FILE      = DATA_DIR / ".sync-state.json"
LOCK_FILE       = DATA_DIR / ".sync.lock"
DEFAULT_SINCE   = 30  # days back for initial sync

# CoreData epoch offset: 978307200 seconds between Unix epoch and 2001-01-01
COREDATA_EPOCH_OFFSET = 978307200

