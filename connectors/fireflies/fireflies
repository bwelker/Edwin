# -- Commands ------------------------------------------------------------------

def cmd_sync(args):
    key = _api_key()
    if not key:
        print("FIREFLIES_API_KEY environment variable is not set.", file=sys.stderr)
        sys.exit(1)

    with SyncLock():
        state = _load_state()
        # "all" = transcripts only (NOT audio/video — on-demand)
        sources = (["transcripts"] if args.source == "all"
                   else [args.source])

        if args.reset:
            for source in sources:
                state.pop(source, None)
            print(f"  State cleared for: {', '.join(sources)}", file=sys.stderr)

        fns = {"transcripts": sync_transcripts, "audio": sync_audio,
               "video": sync_video}
        total = 0
        for source in sources:
            try:
                total += fns[source](state, since_days=args.since, verbose=args.verbose)
            except Exception as e:
                print(f"  {source} sync failed: {e}", file=sys.stderr)
                if args.verbose:
                    import traceback; traceback.print_exc()
            _save_state(state)
        print(f"Sync complete \u2014 {total} total items.", file=sys.stderr)


def cmd_status(args):
    print("Fireflies Sync Status")
    print("=" * 40)
    if not STATE_FILE.exists():
        print("  No state file found")
        return
    try:
        state = json.loads(STATE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        print("  State file corrupted")
        return
    if not state:
        print("  Empty state")
        return

    for source in ("transcripts", "audio", "video"):
        info = state.get(source, {})
        if isinstance(info, dict) and "lastSync" in info:
            print(f"  {source:14s}  last sync: {info['lastSync']}")
        else:
            print(f"  {source:14s}  (not synced)")

    print()
    t_dir = DATA_DIR / "transcripts"
    if t_dir.exists():
        files = list(t_dir.glob("**/*.md"))
        print(f"  {'transcripts':14s}  {len(files)} files on disk")
    a_dir = DATA_DIR / "audio"
    if a_dir.exists():
        files = list(a_dir.glob("**/*.mp3"))
        print(f"  {'audio':14s}  {len(files)} files on disk")
    v_dir = DATA_DIR / "video"
    if v_dir.exists():
        files = list(v_dir.glob("**/*.mp4"))
        print(f"  {'video':14s}  {len(files)} files on disk")
    print()


# -- CLI -----------------------------------------------------------------------

def main():
    p   = argparse.ArgumentParser(description="Edwin Fireflies Connector")
    sub = p.add_subparsers(dest="command", required=True)

    s = sub.add_parser("sync", help="Sync to data/fireflies/")
    s.add_argument("source", choices=["all", "transcripts", "audio", "video"])
    s.add_argument("--since", type=int, default=DEFAULT_SINCE,
                   help=f"Days back for initial/reset sync (default {DEFAULT_SINCE})")
    s.add_argument("--reset", action="store_true",
                   help="Clear saved state and re-fetch from --since days back")
    s.add_argument("--verbose", action="store_true")
    s.set_defaults(func=cmd_sync)

    st = sub.add_parser("status", help="Show last sync times and file counts")
    st.set_defaults(func=cmd_status)

    args = p.parse_args()
    try:
        args.func(args)
    except KeyboardInterrupt:
        print("\nInterrupted.", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        import traceback; traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
