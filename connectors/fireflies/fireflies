# -- State ---------------------------------------------------------------------

def _load_state():
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except json.JSONDecodeError:
            print("  State file corrupted — starting fresh.", file=sys.stderr)
    return {}


def _save_state(state):
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    _atomic_write(STATE_FILE, json.dumps(state, indent=2))


def _atomic_write(path: Path, content: str):
    """Write to temp file then rename — prevents corruption on power loss."""
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=path.parent, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def _atomic_write_binary(path: Path, data: bytes):
    """Atomic binary write for audio/video files."""
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=path.parent, prefix=".tmp-")
    try:
        with os.fdopen(fd, "wb") as f:
            f.write(data)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


# -- Helpers -------------------------------------------------------------------

def _id_hash(item_id: str) -> str:
    return hashlib.sha1(item_id.encode()).hexdigest()[:16]


def _sanitize_filename(name: str) -> str:
    name = re.sub(r'[/\\:*?"<>|]', '-', name)
    name = re.sub(r'-{2,}', '-', name)
    name = name.strip(' .-')
    return (name or "unnamed")[:50]


def _since_dt(days: int) -> datetime:
    return datetime.now(pytz.utc) - timedelta(days=days)


def _try_parse_iso(ts: str) -> datetime:
    """Parse ISO 8601 timestamp. Returns epoch-zero on failure."""
    try:
        return datetime.fromisoformat(ts.replace("Z", "+00:00"))
    except (ValueError, TypeError, AttributeError):
        return datetime(1970, 1, 1, tzinfo=pytz.utc)


def _ts_to_dt(ts_ms) -> datetime:
    """Convert Fireflies millisecond timestamp to datetime."""
    if not ts_ms:
        return datetime(1970, 1, 1, tzinfo=pytz.utc)
    try:
        return datetime.fromtimestamp(ts_ms / 1000, tz=pytz.utc)
    except (ValueError, TypeError, OSError):
        return datetime(1970, 1, 1, tzinfo=pytz.utc)


def _format_duration(minutes):
    """Format duration from minutes (float) to human readable."""
    if not minutes:
        return "0m"
    try:
        total_seconds = int(float(minutes) * 60)
    except (ValueError, TypeError):
        return "0m"
    hours, remainder = divmod(total_seconds, 3600)
    mins = remainder // 60
    if hours:
        return f"{hours}h {mins}m"
    return f"{mins}m"


def _format_timecode(seconds_str):
    """Format a seconds value as MM:SS or HH:MM:SS."""
    try:
        total = int(float(seconds_str))
    except (ValueError, TypeError):
        return "00:00"
    hours, remainder = divmod(total, 3600)
    mins, secs = divmod(remainder, 60)
    if hours:
        return f"{hours}:{mins:02d}:{secs:02d}"
    return f"{mins:02d}:{secs:02d}"


def _strip_html(html) -> str:
    if not isinstance(html, str):
        return str(html) if html else ""
    html = re.sub(r'<style[^>]*>.*?</style>', '', html, flags=re.DOTALL | re.IGNORECASE)
    html = re.sub(r'<script[^>]*>.*?</script>', '', html, flags=re.DOTALL | re.IGNORECASE)
    html = re.sub(r'<br\s*/?>', '\n', html, flags=re.IGNORECASE)
    html = re.sub(r'</?p[^>]*>', '\n', html, flags=re.IGNORECASE)
    html = re.sub(r'</?div[^>]*>', '\n', html, flags=re.IGNORECASE)
    html = re.sub(r'</?li[^>]*>', '\n- ', html, flags=re.IGNORECASE)
    html = re.sub(r'<[^>]+>', '', html)
    html = html_mod.unescape(html)
    return re.sub(r'\n{3,}', '\n\n', html).strip()


def _transcript_path(dt: datetime, title: str) -> Path:
    """Generate path for a transcript file: YYYY-MM/YYYY-MM-DD-<title>.md"""
    tz = pytz.timezone(TZ)
    local_dt = dt.astimezone(tz)
    folder = DATA_DIR / "transcripts" / local_dt.strftime("%Y-%m")
    folder.mkdir(parents=True, exist_ok=True)
    safe_title = _sanitize_filename(title)
    return folder / f"{local_dt.strftime('%Y-%m-%d')}-{safe_title}.md"


def _transcript_exists(transcript_id: str) -> bool:
    """Check if a transcript with this ID already exists anywhere in transcripts dir."""
    transcripts_dir = DATA_DIR / "transcripts"
    if not transcripts_dir.exists():
        return False
    marker = f"idhash: {_id_hash(transcript_id)}"
    for md_file in transcripts_dir.glob("**/*.md"):
        try:
            if marker in md_file.read_text(encoding="utf-8"):
                return True
        except OSError:
            continue
    return False


# -- Formatter -----------------------------------------------------------------

def _format_transcript(t: dict, analytics: dict = None) -> str:
    """Format a full transcript as an embedder-friendly markdown file."""
    tz = pytz.timezone(TZ)

    # Metadata
    t_id         = t.get("id", "")
    title        = t.get("title") or "Untitled Meeting"
    date_ms      = t.get("date")
    duration     = t.get("duration")
    organizer    = t.get("organizer_email", "")
    participants = t.get("participants") or []
    meeting_link = t.get("meeting_link", "")
    speakers     = t.get("speakers") or []
    summary      = t.get("summary") or {}
    sentences    = t.get("sentences") or []
    attendees    = t.get("meeting_attendees") or []
    attendance   = t.get("meeting_attendance") or []
    meeting_info = t.get("meeting_info") or {}

    dt = _ts_to_dt(date_ms).astimezone(tz)
    dur_str = _format_duration(duration)
    date_str = dt.strftime("%Y-%m-%d %I:%M %p")
    speaker_names = [s.get("name", "Unknown") for s in speakers]
    attendee_names = [a.get("displayName") or a.get("name") or a.get("email", "Unknown") for a in attendees]
    meeting_type = summary.get("meeting_type", "")
    summary_status = meeting_info.get("summary_status", "")

    # Context line repeated in each section for embedder chunk independence
    ctx = f"*{title} ({dt.strftime('%Y-%m-%d')}, {dur_str})*"

    lines = [
        "---",
        f"source: fireflies-transcript",
        f"idhash: {_id_hash(t_id)}",
        f"fireflies_id: {t_id}",
        f"title: {title}",
        f"date: {dt.isoformat()}",
        f"duration: {dur_str}",
        f"organizer: {organizer}",
        f"participants: {', '.join(participants)}",
        f"meeting_link: {meeting_link}",
        f"meeting_type: {meeting_type}",
        f"speakers: {', '.join(speaker_names)}",
        f"summary_status: {summary_status}",
        "---",
        "",
        f"# {title}",
        "",
        f"**Date:** {date_str} | **Duration:** {dur_str} | **Participants:** {', '.join(attendee_names) or ', '.join(participants) or 'Unknown'}",
        "",
    ]

    # Attendance info
    if attendance:
        lines.append("**Attendance:**")
        for a in attendance:
            name = a.get("name", "Unknown")
            join = a.get("join_time", "")
            leave = a.get("leave_time", "")
            leave_str = f" — left {leave}" if leave else ""
            lines.append(f"- {name} (joined {join}{leave_str})")
        lines.append("")

    # Summary sections — each with context line
    if summary.get("overview"):
        lines.extend(["### Summary", ctx, "", _strip_html(summary["overview"]), ""])
    if summary.get("bullet_gist"):
        lines.extend(["### Key Points", ctx, "", _strip_html(summary["bullet_gist"]), ""])
    if summary.get("action_items"):
        lines.extend(["### Action Items", ctx, "", _strip_html(summary["action_items"]), ""])
    if summary.get("outline"):
        lines.extend(["### Outline", ctx, "", _strip_html(summary["outline"]), ""])
    if summary.get("topics_discussed"):
        topics = summary["topics_discussed"]
        if isinstance(topics, list):
            topic_str = "\n".join(f"- {t}" for t in topics)
        else:
            topic_str = str(topics)
        lines.extend(["### Topics", ctx, "", topic_str, ""])
    if summary.get("notes"):
        lines.extend(["### Notes", ctx, "", _strip_html(summary["notes"]), ""])
    if summary.get("short_summary"):
        lines.extend(["### Short Summary", ctx, "", _strip_html(str(summary["short_summary"])), ""])
    if summary.get("keywords"):
        kw = summary["keywords"]
        if isinstance(kw, list):
            kw_str = ", ".join(str(k) for k in kw)
        else:
            kw_str = _strip_html(str(kw))
        lines.extend(["### Keywords", ctx, "", kw_str, ""])
    if summary.get("transcript_chapters"):
        chapters = summary["transcript_chapters"]
        if isinstance(chapters, list):
            ch_str = "\n\n".join(str(c) for c in chapters)
        else:
            ch_str = str(chapters)
        lines.extend(["### Chapters", ctx, "", ch_str, ""])

    # Analytics
    if analytics:
        sentiments = analytics.get("sentiments") or {}
        spk_stats = analytics.get("speakers") or []

        lines.extend(["### Analytics", ctx, ""])

        if sentiments:
            pos = sentiments.get("positive_pct", 0)
            neg = sentiments.get("negative_pct", 0)
            neu = sentiments.get("neutral_pct", 0)
            lines.append(f"**Sentiment:** {pos:.0f}% positive, {neg:.0f}% negative, {neu:.0f}% neutral")
            lines.append("")

        if spk_stats:
            lines.append("| Speaker | Talk Time | Words | WPM | Filler Words | Questions |")
            lines.append("|---------|-----------|-------|-----|-------------|-----------|")
            for s in spk_stats:
                name = s.get("name", "Unknown")
                dur = f"{s.get('duration', 0):.0f}s"
                words = s.get("word_count", 0)
                wpm = f"{s.get('words_per_minute', 0):.0f}"
                fillers = s.get("filler_words", 0)
                questions = s.get("questions", 0)
                lines.append(f"| {name} | {dur} | {words} | {wpm} | {fillers} | {questions} |")
            lines.append("")

    # Transcript — group by speaker turns
    if sentences:
        lines.extend(["### Transcript", ctx, ""])

        current_speaker = None
        current_text_parts = []
        current_start = None

        for sent in sentences:
            speaker = sent.get("speaker_name", "Unknown")
            text = sent.get("text", "")
            if not text:
                text = sent.get("raw_text", "")
            if not text:
                continue
            text = _strip_html(text).strip()
            start = sent.get("start_time", "")

            if speaker != current_speaker:
                # Flush previous speaker's turn
                if current_speaker is not None and current_text_parts:
                    tc = _format_timecode(current_start) if current_start else ""
                    tc_str = f" ({tc})" if tc else ""
                    lines.append(f"**{current_speaker}**{tc_str}: {' '.join(current_text_parts)}")
                    lines.append("")
                current_speaker = speaker
                current_text_parts = [text]
                current_start = start
            else:
                current_text_parts.append(text)

        # Flush last turn
        if current_speaker and current_text_parts:
            tc = _format_timecode(current_start) if current_start else ""
            tc_str = f" ({tc})" if tc else ""
            lines.append(f"**{current_speaker}**{tc_str}: {' '.join(current_text_parts)}")
            lines.append("")

    return "\n".join(lines)


def _build_sidecar(t: dict) -> dict:
    """Build diarization sidecar data from transcript sentences."""
    sentences = t.get("sentences") or []
    sidecar = {
        "transcript_id": t.get("id", ""),
        "title": t.get("title", ""),
        "speakers": [{"id": s.get("id"), "name": s.get("name")} for s in (t.get("speakers") or [])],
        "sentences": [],
    }
    for sent in sentences:
        sidecar["sentences"].append({
            "index": sent.get("index"),
            "speaker_id": sent.get("speaker_id"),
            "speaker_name": sent.get("speaker_name", "Unknown"),
            "start_time": sent.get("start_time"),
            "end_time": sent.get("end_time"),
            "text": sent.get("text", ""),
            "raw_text": sent.get("raw_text", ""),
        })
    return sidecar


# -- Sync: Transcripts --------------------------------------------------------

def sync_transcripts(state: dict, since_days: int = DEFAULT_SINCE, verbose: bool = False) -> int:
    tz = pytz.timezone(TZ)
    last_sync = state.get("transcripts", {}).get("lastSync")

    if last_sync:
        since = _try_parse_iso(last_sync)
        print(f"  Syncing transcripts since {last_sync}...", file=sys.stderr)
    else:
        since = _since_dt(since_days)
        print(f"  Backfilling transcripts {since_days} days...", file=sys.stderr)

    # Phase 1: List transcripts
    from_date = since.isoformat()
    all_ids = []
    skip = 0

    while True:
        variables = {"limit": 50, "skip": skip, "fromDate": from_date}
        data = _graphql(TRANSCRIPTS_LIST_QUERY, variables)
        page = data.get("data", {}).get("transcripts") or []
        if not page:
            break
        all_ids.extend(page)
        if len(page) < 50:
            break
        skip += 50
        if verbose:
            print(f"    Listed {len(all_ids)} transcripts so far...", file=sys.stderr)

    print(f"  Found {len(all_ids)} transcripts in range", file=sys.stderr)

    # Phase 2: Fetch details and write
    count = 0
    for item in all_ids:
        t_id = item.get("id", "")
        title = item.get("title", "Untitled")
        if not t_id:
            continue

        # Dedup check
        if _transcript_exists(t_id):
            if verbose:
                print(f"    Skipped: {title} (exists)", file=sys.stderr)
            continue

        if verbose:
            print(f"    Fetching: {title}...", file=sys.stderr)

        try:
            # Fetch full detail
            data = _graphql(TRANSCRIPT_DETAIL_QUERY, {"transcriptId": t_id})
            t = data.get("data", {}).get("transcript")
            if not t:
                print(f"    Warning: no detail for {t_id}", file=sys.stderr)
                continue

            # Fetch analytics (may fail on Free/Pro plans)
            analytics = None
            try:
                adata = _graphql(TRANSCRIPT_ANALYTICS_QUERY, {"transcriptId": t_id})
                analytics = (adata.get("data", {}).get("transcript") or {}).get("analytics")
            except (FirefliesError, Exception):
                pass  # Analytics not available on this plan

            # Format and write
            date_ms = t.get("date")
            dt = _ts_to_dt(date_ms)
            path = _transcript_path(dt, title)

            content = _format_transcript(t, analytics)
            _atomic_write(path, content)
            count += 1

            if verbose:
                print(f"    Written: {path.name}", file=sys.stderr)

        except Exception as e:
            print(f"    Error on {title}: {e}", file=sys.stderr)

    state.setdefault("transcripts", {})["lastSync"] = datetime.now(pytz.utc).isoformat()
    print(f"  Transcripts: {count} new items", file=sys.stderr)
    return count


# -- Sync: Audio (on-demand) --------------------------------------------------

def sync_audio(state: dict, since_days: int = DEFAULT_SINCE, verbose: bool = False) -> int:
    tz = pytz.timezone(TZ)
    last_sync = state.get("audio", {}).get("lastSync")

    if last_sync:
        since = _try_parse_iso(last_sync)
        print(f"  Downloading audio since {last_sync}...", file=sys.stderr)
    else:
        since = _since_dt(since_days)
        print(f"  Downloading audio {since_days} days...", file=sys.stderr)

    from_date = since.isoformat()
    count = 0

    # List transcripts in range
    skip = 0
    while True:
        variables = {"limit": 50, "skip": skip, "fromDate": from_date}
        data = _graphql(TRANSCRIPTS_LIST_QUERY, variables)
        page = data.get("data", {}).get("transcripts") or []
        if not page:
            break

        for item in page:
            t_id = item.get("id", "")
            title = item.get("title", "Untitled")
            date_ms = item.get("date")
            if not t_id:
                continue

            dt = _ts_to_dt(date_ms).astimezone(tz)
            safe_title = _sanitize_filename(title)
            audio_dir = DATA_DIR / "audio" / dt.strftime("%Y-%m")
            audio_dir.mkdir(parents=True, exist_ok=True)
            audio_path = audio_dir / f"{dt.strftime('%Y-%m-%d')}-{safe_title}.mp3"
            sidecar_path = audio_path.with_suffix(".json")

            if audio_path.exists():
                if verbose:
                    print(f"    Skipped: {audio_path.name} (exists)", file=sys.stderr)
                continue

            if verbose:
                print(f"    Fetching audio URL for: {title}...", file=sys.stderr)

            try:
                # Get fresh audio_url (expires in 24h)
                detail = _graphql(TRANSCRIPT_DETAIL_QUERY, {"transcriptId": t_id})
                t = detail.get("data", {}).get("transcript") or {}
                audio_url = t.get("audio_url")

                if not audio_url:
                    if verbose:
                        print(f"    No audio URL for: {title}", file=sys.stderr)
                    continue

                if verbose:
                    print(f"    Downloading: {audio_path.name}...", file=sys.stderr)

                audio_data = _download_url(audio_url, timeout=300)
                _atomic_write_binary(audio_path, audio_data)

                # Write diarization sidecar
                sidecar = _build_sidecar(t)
                _atomic_write(sidecar_path, json.dumps(sidecar, indent=2))

                count += 1
                if verbose:
                    print(f"    Written: {audio_path.name} + sidecar", file=sys.stderr)

            except Exception as e:
                print(f"    Audio download failed for {title}: {e}", file=sys.stderr)

        if len(page) < 50:
            break
        skip += 50

    state.setdefault("audio", {})["lastSync"] = datetime.now(pytz.utc).isoformat()
    print(f"  Audio: {count} files downloaded", file=sys.stderr)
    return count


