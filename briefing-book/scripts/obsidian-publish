#!/usr/bin/env python3
"""
Publish briefing book files to an Obsidian vault.

Usage:
    obsidian-publish <file>                  # publish one file, vault path derived from docs/ relative path
    obsidian-publish <file> <vault-path>     # publish one file to explicit vault-relative path
    obsidian-publish --all                   # publish everything in docs/
    obsidian-publish --section "1. Briefs"   # publish one section
    obsidian-publish --status                # show what would be published (dry run)
    obsidian-publish --setup                 # interactive vault setup

Vault path resolution (first match wins):
    1. OBSIDIAN_VAULT_PATH env var
    2. ~/.edwin/obsidian-vault-path config file
    3. Auto-detect common Obsidian locations + OBSIDIAN_VAULT_NAME subdirectory

Publishes from: briefing-book/docs/
"""

import argparse
import hashlib
import os
import platform
import shutil
import sys
from pathlib import Path

DOCS_DIR = Path(__file__).resolve().parent.parent / "docs"
CONFIG_FILE = Path.home() / ".edwin" / "obsidian-vault-path"
DEFAULT_VAULT_NAME = "Edwin Briefing Book"


def _vault_name() -> str:
    """Return the vault subdirectory name."""
    return os.environ.get("OBSIDIAN_VAULT_NAME", DEFAULT_VAULT_NAME)


def _detect_obsidian_root() -> Path | None:
    """Try to find the Obsidian documents root for the current platform."""
    system = platform.system()
    if system == "Darwin":
        candidate = Path.home() / "Library/Mobile Documents/iCloud~md~obsidian/Documents"
        if candidate.exists():
            return candidate
    elif system == "Linux":
        # Check Obsidian config for vault registry -- but don't parse it,
        # just confirm Obsidian is installed. Users should use --setup or config.
        obsidian_config = Path.home() / ".config/obsidian"
        if obsidian_config.exists():
            # Can't reliably determine vault root on Linux; fall through to config.
            pass
    return None


def resolve_vault_dir() -> Path | None:
    """Resolve the vault directory. Returns None if not configured and auto-detect fails."""
    # 1. Env var (full path, no vault name appended)
    env_path = os.environ.get("OBSIDIAN_VAULT_PATH")
    if env_path:
        return Path(env_path).expanduser()

    # 2. Config file (full path, no vault name appended)
    if CONFIG_FILE.exists():
        configured = CONFIG_FILE.read_text().strip()
        if configured:
            return Path(configured).expanduser()

    # 3. Auto-detect
    root = _detect_obsidian_root()
    if root:
        return root / _vault_name()

    return None


def file_hash(path: Path) -> str:
    """SHA256 of file contents."""
    return hashlib.sha256(path.read_bytes()).hexdigest()


def publish_file(src: Path, vault_dir: Path, vault_relative: Path = None) -> bool:
    """Copy one file from docs/ to the vault. Returns True if file was updated.

    Respects iCloud edits: if the vault file is newer than the local file
    AND has different content, the vault version wins (skip the publish).
    This prevents overwriting Obsidian edits or iCloud-side moves.
    """
    if vault_relative is None:
        try:
            vault_relative = src.relative_to(DOCS_DIR)
        except ValueError:
            print(f"ERROR: {src} is not under {DOCS_DIR}", file=sys.stderr)
            return False

    dest = vault_dir / vault_relative
    dest.parent.mkdir(parents=True, exist_ok=True)

    # Skip if identical
    if dest.exists() and file_hash(src) == file_hash(dest):
        return False

    # Skip if vault file is newer (edited in Obsidian or written directly to iCloud)
    if dest.exists() and dest.stat().st_mtime > src.stat().st_mtime:
        return False

    shutil.copy2(src, dest)
    return True


def publish_all(vault_dir: Path, root: Path = None) -> tuple[int, int]:
    """Publish all .md files under root. Returns (published, skipped)."""
    if root is None:
        root = DOCS_DIR

    published = 0
    skipped = 0

    for md_file in sorted(root.rglob("*.md")):
        if publish_file(md_file, vault_dir):
            rel = md_file.relative_to(DOCS_DIR)
            print(f"  published: {rel}")
            published += 1
        else:
            skipped += 1

    return published, skipped


def status(vault_dir: Path) -> None:
    """Show what would be published."""
    for md_file in sorted(DOCS_DIR.rglob("*.md")):
        rel = md_file.relative_to(DOCS_DIR)
        dest = vault_dir / rel
        if not dest.exists():
            print(f"  NEW: {rel}")
        elif file_hash(md_file) != file_hash(dest):
            if dest.stat().st_mtime > md_file.stat().st_mtime:
                print(f"  VAULT-NEWER: {rel} (iCloud edit wins, skipped)")
            else:
                print(f"  CHANGED: {rel}")


def setup() -> None:
    """Interactive vault setup."""
    print("Obsidian Vault Setup")
    print("=" * 40)
    print()
    print("This creates a new vault -- it won't touch your existing Obsidian data.")
    print()

    vault_name = _vault_name()
    system = platform.system()

    # Suggest platform-appropriate locations
    suggestions = []
    if system == "Darwin":
        icloud_root = Path.home() / "Library/Mobile Documents/iCloud~md~obsidian/Documents"
        if icloud_root.exists():
            suggestions.append(("iCloud (syncs across devices)", icloud_root / vault_name))
        suggestions.append(("Home directory", Path.home() / vault_name))
    elif system == "Linux":
        suggestions.append(("Home directory", Path.home() / vault_name))
        suggestions.append(("Documents", Path.home() / "Documents" / vault_name))
    else:
        suggestions.append(("Home directory", Path.home() / vault_name))

    print("Where should the vault live?")
    print()
    for i, (label, path) in enumerate(suggestions, 1):
        print(f"  {i}. {label}")
        print(f"     {path}")
        print()
    print(f"  {len(suggestions) + 1}. Custom path")
    print()

    try:
        choice = input(f"Choose [1-{len(suggestions) + 1}]: ").strip()
    except (EOFError, KeyboardInterrupt):
        print("\nSetup cancelled.")
        return

    try:
        idx = int(choice)
    except ValueError:
        print("Invalid choice.")
        return

    if idx == len(suggestions) + 1:
        try:
            custom = input("Enter full path: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nSetup cancelled.")
            return
        vault_path = Path(custom).expanduser()
    elif 1 <= idx <= len(suggestions):
        vault_path = suggestions[idx - 1][1]
    else:
        print("Invalid choice.")
        return

    # Create the vault directory
    vault_path.mkdir(parents=True, exist_ok=True)

    # Write config
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(str(vault_path) + "\n")

    print()
    print(f"Vault directory created: {vault_path}")
    print(f"Config saved to: {CONFIG_FILE}")
    print()
    print(f"Next step: Open Obsidian > Open folder as vault > select:")
    print(f"  {vault_path}")
    print()
    print("Then run: obsidian-publish --all")


def main():
    parser = argparse.ArgumentParser(description="Publish briefing book to Obsidian vault")
    parser.add_argument("file", nargs="?", help="File to publish")
    parser.add_argument("vault_path", nargs="?", help="Explicit vault-relative path")
    parser.add_argument("--all", action="store_true", help="Publish everything")
    parser.add_argument("--section", help="Publish one section (e.g. '1. Briefs')")
    parser.add_argument("--status", action="store_true", help="Dry run -- show what would change")
    parser.add_argument("--setup", action="store_true", help="Interactive vault setup")
    args = parser.parse_args()

    if args.setup:
        setup()
        return

    vault_dir = resolve_vault_dir()
    if vault_dir is None:
        print("No Obsidian vault configured. Run: obsidian-publish --setup", file=sys.stderr)
        sys.exit(1)

    if not vault_dir.exists():
        print(f"Vault directory does not exist: {vault_dir}", file=sys.stderr)
        print("Run: obsidian-publish --setup", file=sys.stderr)
        sys.exit(1)

    if args.status:
        status(vault_dir)
    elif args.all:
        published, skipped = publish_all(vault_dir)
        print(f"Published {published}, skipped {skipped} (unchanged)")
    elif args.section:
        section_dir = DOCS_DIR / args.section
        if not section_dir.exists():
            print(f"ERROR: Section not found: {section_dir}", file=sys.stderr)
            sys.exit(1)
        published, skipped = publish_all(vault_dir, section_dir)
        print(f"Published {published}, skipped {skipped} (unchanged)")
    elif args.file:
        src = Path(args.file).resolve()
        vault_rel = Path(args.vault_path) if args.vault_path else None
        if publish_file(src, vault_dir, vault_rel):
            print(f"Published: {src.name}")
        else:
            print(f"Unchanged: {src.name}")
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
