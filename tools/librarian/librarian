#   "globs":    artifact glob patterns relative to EDWIN_HOME (newest match wins),
#   "schedule": ("weekdays", H, M) | ("daily", H, M) | ("weekly", DOW, H, M)
#               | ("interval", HOURS) | ("times", H, H, ...)   -- DOW: 0=Monday
#               ("times", ...) = daily at several hours (cron hour="7,12,17")
