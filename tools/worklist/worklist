#!/usr/bin/env python3
"""
Worklist -- the living assistant-does vs principal-does split.

A VIEW over the PM database (read-only -- PM stays the single store) that
splits everything in flight into what only the principal can do, what sits
with them but could be handed off (the chief-of-staff edge), and what the
assistant is already carrying.

Usage:
    worklist generate               # Worklist.md -> Action Tracker + Obsidian
    worklist generate --no-publish  # skip obsidian-publish (testing)
    worklist status                 # one-line section counts (for embedding)

Output: briefing-book/docs/3. \U0001f3af Action Tracker/Worklist.md
A LIVING doc, overwritten each run. Git history in the vault covers history.

Sections:
    PRINCIPAL-ONLY owner=principal, inherently theirs (decisions, approvals,
                   personnel, exec/board, legal/money, personal, hard
                   conversations). Sorted priority + due.
    DELEGABLE      owner=principal but pattern-matches a delegable class.
                   Each line carries a proposed delegate (the assistant or a
                   named team role) and a one-line why. This is the standing
                   order made operational.
    ASSISTANT-ACTIVE  owner=assistant open items, one-liners.
    NEXT-CHAPTER GUARD  fixed footer: principal-only vs delegable counts,
                   plus one dry line (rotates weekly) when delegable wins.

Hard rules:
    - READ-ONLY against the PM DB (mode=ro). Never mutates items.
    - Uncertain classification -> PRINCIPAL-ONLY. Never over-claim delegability.
    - No em dashes in generated text. One guard line, never a lecture.

Config note: the classification rules below are EXAMPLE seed rules. Tune the
patterns, delegate roles, and personal/family keywords to your own context --
that is the intended way to adopt this tool.

Scheduled: Plombery `sys-worklist`, weekdays 6:20 AM.
"""

import argparse
import os
import re
import sqlite3
import subprocess
import sys
from datetime import date, datetime
from pathlib import Path

EDWIN_HOME = Path(os.environ.get("EDWIN_HOME", Path.home() / "Edwin"))
TOOL_DIR = Path(__file__).resolve().parent
PROJECT_DIR = EDWIN_HOME
DB_PATH = PROJECT_DIR / "data" / "pm" / "prospective.db"
TRACKER_DIR = PROJECT_DIR / "briefing-book" / "docs" / "3. \U0001f3af Action Tracker"
PUBLISH_SCRIPT = PROJECT_DIR / "briefing-book" / "scripts" / "obsidian-publish"
OUT_PATH = TRACKER_DIR / "Worklist.md"

# Who owns the "principal" side. Override PRINCIPAL_NAME to match your PM data.
PRINCIPAL_NAME = os.environ.get("PRINCIPAL_NAME", "principal").strip().lower()
PRINCIPAL_LABEL = PRINCIPAL_NAME.capitalize()
PRINCIPAL_NAMES = {PRINCIPAL_NAME, "principal", "owner"}
ASSISTANT_NAMES = {"edwin", "assistant"}

PRIORITY_ORDER = {"critical": 0, "high": 1, "medium": 2, "low": 3}

# =============================================================================
# CONFIG -- classification rules. Evaluated in order; FIRST MATCH WINS.
# Tune here, nowhere else. Patterns run over the DESCRIPTION only -- context
# fields are conversational noise (a context mentioning the CEO or a bonus does
