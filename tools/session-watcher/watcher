#!/usr/bin/env python3
"""
Session Watcher -- Detects when a Claude Code session needs state capture.

Monitors the active Claude Code JSONL session file for two conditions:
  1. Idle timeout: User hasn't sent a message in >N minutes (default 60)
  2. Token threshold: Context usage approaching the model's window limit

When either condition is met, outputs a capture recommendation with session
metadata. A separate summarizer script handles the actual LLM summarization.

Exit codes:
  0 -- always (output is the decision as JSON)

Output (JSON):
  { "action": "capture"|"skip", "reason": "...", "trigger": "idle"|"tokens"|null,
    "session_file": "...", "session_id": "...", "model": "...",
    "tokens_used": N, "context_window": N, "utilization_pct": N,
    "last_user_ts": "...", "idle_minutes": N, "message_count": N }

Usage:
  watcher                              # Check active session
  watcher --idle-minutes 60            # Custom idle threshold (default 60)
  watcher --token-pct 70               # Custom token threshold % (default 70)
  watcher --update-state               # Mark current session as captured
  watcher --status                     # Show current session stats
"""

import argparse
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

# Session directory: auto-detect from EDWIN_SESSIONS_DIR env var,
# or fall back to the Claude Code project sessions for this project.
_project_dir = Path(__file__).resolve().parent.parent.parent
SESSIONS_DIR = Path(
    os.environ.get(
        "EDWIN_SESSIONS_DIR",
        str(Path.home() / ".claude" / "projects" / f"-{str(_project_dir).replace('/', '-').lstrip('-')}"),
    )
)
STATE_FILE = _project_dir / "memory" / ".session-watcher-state.json"

DEFAULT_IDLE_MINUTES = 60
DEFAULT_TOKEN_PCT = 70

# Model name -> context window size (tokens)
CONTEXT_WINDOWS = {
    "claude-opus-4-6": 1_000_000,
    "claude-sonnet-4-6": 200_000,
    "claude-sonnet-4-5": 200_000,
    "claude-haiku-4-5": 200_000,
    "claude-sonnet-4-5-20250514": 200_000,
    # Fallback for unknown models
}
DEFAULT_CONTEXT_WINDOW = 200_000


def find_active_session() -> Path | None:
    """Find the most recently modified JSONL session file.

    Tiebreak on file size -- main sessions are always larger than subagent sessions.
    """
    if not SESSIONS_DIR.exists():
        return None
    jsonl_files = list(SESSIONS_DIR.glob("*.jsonl"))
    if not jsonl_files:
        return None
    return max(jsonl_files, key=lambda f: (f.stat().st_mtime, f.stat().st_size))


def parse_session(session_file: Path) -> dict:
    """Parse a Claude Code JSONL session file for watcher-relevant data.

    Returns dict with: model, tokens_used, context_window, last_user_ts,
    idle_minutes, message_count, thinking_chars.
    """
    model = None
    last_tokens_used = 0
    last_user_ts = None
    user_msg_count = 0
    assistant_msg_count = 0
    thinking_chars = 0

    with open(session_file) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
            except json.JSONDecodeError:
                continue

            entry_type = entry.get("type")
            msg = entry.get("message", {})
            ts = entry.get("timestamp")

            if entry_type == "user":
                # Skip tool results -- only count actual user messages
                if "toolUseResult" not in entry:
                    user_msg_count += 1
                    last_user_ts = ts

            elif entry_type == "assistant":
                assistant_msg_count += 1

                # Extract model
                msg_model = msg.get("model") or entry.get("model")
                if msg_model:
                    model = msg_model

                # Extract token usage
                usage = msg.get("usage") or entry.get("usage")
                if usage:
                    total = (
                        usage.get("cache_read_input_tokens", 0)
                        + usage.get("cache_creation_input_tokens", 0)
                        + usage.get("input_tokens", 0)
                        + usage.get("output_tokens", 0)
                    )
                    if total > last_tokens_used:
                        last_tokens_used = total

                # Count thinking tokens (estimated from text)
                content = msg.get("content", [])
                if isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get("type") == "thinking":
                            thinking_chars += len(block.get("thinking", ""))

    # Determine context window from model
    context_window = CONTEXT_WINDOWS.get(model, DEFAULT_CONTEXT_WINDOW)

    # Calculate idle time
    idle_minutes = None
    if last_user_ts:
        try:
            user_dt = datetime.fromisoformat(last_user_ts.replace("Z", "+00:00"))
            now = datetime.now(timezone.utc)
            idle_minutes = round((now - user_dt).total_seconds() / 60)
        except (ValueError, AttributeError):
            pass

    return {
        "model": model,
        "tokens_used": last_tokens_used,
        "context_window": context_window,
        "utilization_pct": round(last_tokens_used / context_window * 100, 1) if context_window else 0,
        "last_user_ts": last_user_ts,
        "idle_minutes": idle_minutes,
        "message_count": user_msg_count + assistant_msg_count,
        "user_messages": user_msg_count,
        "thinking_chars": thinking_chars,
        "thinking_tokens_est": thinking_chars // 4,
    }


def load_state() -> dict:
    """Load watcher state file."""
    if not STATE_FILE.exists():
        return {"last_capture_ts": None, "last_capture_session": None}
    try:
        return json.loads(STATE_FILE.read_text())
    except (json.JSONDecodeError, IOError):
        return {"last_capture_ts": None, "last_capture_session": None}


def save_state(session_file: Path, capture_ts: str):
    """Update state after successful capture."""
    state = {
        "last_capture_ts": capture_ts,
        "last_capture_session": session_file.stem,
        "updated_at": datetime.now(timezone.utc).isoformat(),
    }
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, indent=2))


def cmd_check(args):
    """Main check: should we capture?"""
    session_file = find_active_session()
    if not session_file:
        print(json.dumps({"action": "skip", "reason": "no session files found"}))
        return

    session_id = session_file.stem
    info = parse_session(session_file)

    base = {
        "session_file": str(session_file),
        "session_id": session_id,
        **info,
    }

    # No user messages = nothing to capture
    if info["user_messages"] == 0:
        print(json.dumps({"action": "skip", "reason": "no user messages", **base}))
        return

    # Check against last capture
    state = load_state()
    last_capture_ts = state.get("last_capture_ts")
    last_capture_session = state.get("last_capture_session")

    # If same session and already captured after last user message
    if last_capture_session == session_id and last_capture_ts and info["last_user_ts"]:
        try:
            capture_dt = datetime.fromisoformat(last_capture_ts.replace("Z", "+00:00"))
            user_dt = datetime.fromisoformat(info["last_user_ts"].replace("Z", "+00:00"))
            if user_dt <= capture_dt:
                print(json.dumps({
                    "action": "skip",
                    "reason": "already captured (no new conversation since last capture)",
                    "last_capture_ts": last_capture_ts,
                    **base,
                }))
                return
        except (ValueError, AttributeError):
            pass

    # Check token threshold
    if info["utilization_pct"] >= args.token_pct:
        result = {
            "action": "capture",
            "trigger": "tokens",
            "reason": f"context at {info['utilization_pct']}% ({info['tokens_used']:,} / {info['context_window']:,} tokens)",
            **base,
        }
        if args.update_state:
            save_state(session_file, datetime.now(timezone.utc).isoformat())
        print(json.dumps(result))
        return

    # Check idle timeout
    if info["idle_minutes"] is not None and info["idle_minutes"] >= args.idle_minutes:
        result = {
            "action": "capture",
            "trigger": "idle",
            "reason": f"idle {info['idle_minutes']}m with uncaptured conversation ({info['message_count']} messages)",
            **base,
        }
        if args.update_state:
            save_state(session_file, datetime.now(timezone.utc).isoformat())
        print(json.dumps(result))
        return

    # No capture needed
    reasons = []
    if info["idle_minutes"] is not None:
        reasons.append(f"idle {info['idle_minutes']}m < {args.idle_minutes}m threshold")
    reasons.append(f"tokens at {info['utilization_pct']}% < {args.token_pct}% threshold")
    print(json.dumps({
        "action": "skip",
        "reason": "; ".join(reasons),
        **base,
    }))


def cmd_status(args):
    """Show current session stats."""
    session_file = find_active_session()
    if not session_file:
        print("No active session found.")
        return

    info = parse_session(session_file)
    state = load_state()

    print(f"Session:    {session_file.stem}")
    print(f"Model:      {info['model']}")
    print(f"Messages:   {info['message_count']} ({info['user_messages']} user)")
    print(f"Tokens:     {info['tokens_used']:,} / {info['context_window']:,} ({info['utilization_pct']}%)")
    print(f"Thinking:   ~{info['thinking_tokens_est']:,} tokens ({info['thinking_chars']:,} chars)")
    print(f"Idle:       {info['idle_minutes']}m" if info['idle_minutes'] is not None else "Idle:       unknown")
    print(f"Last capture: {state.get('last_capture_ts', 'never')}")


def main():
    parser = argparse.ArgumentParser(description="Session watcher for Claude Code")
    parser.add_argument("--idle-minutes", type=int, default=DEFAULT_IDLE_MINUTES,
                        help=f"Idle threshold in minutes (default {DEFAULT_IDLE_MINUTES})")
    parser.add_argument("--token-pct", type=int, default=DEFAULT_TOKEN_PCT,
                        help=f"Token utilization threshold %% (default {DEFAULT_TOKEN_PCT})")
    parser.add_argument("--update-state", action="store_true",
                        help="Mark session as captured after recommending capture")
    parser.add_argument("--status", action="store_true",
                        help="Show current session stats")
    args = parser.parse_args()

    if args.status:
        cmd_status(args)
    else:
        cmd_check(args)


if __name__ == "__main__":
    main()
