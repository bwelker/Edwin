# -- Helpers ------------------------------------------------------------------

def _load_admin_key():
    if not ADMIN_KEY_FILE.exists():
        return None
    for line in ADMIN_KEY_FILE.read_text().splitlines():
        if line.startswith("ANTHROPIC_ADMIN_API_KEY="):
            return line.split("=", 1)[1].strip()
    return None


def _api_get(url, api_key):
    req = Request(url, headers={
        "x-api-key": api_key,
        "anthropic-version": "2023-06-01",
    })
    try:
        with urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except Exception as e:
        return {"error": str(e)}


def _qdrant_get(path):
    try:
        with urlopen(f"{QDRANT_URL}{path}", timeout=10) as resp:
            return json.loads(resp.read())
    except Exception:
        return None


def _check_service(url, timeout=5):
    try:
        urlopen(url, timeout=timeout)
        return True
    except Exception:
        return False


def _neo4j_auth_header():
    """Basic-auth header for Neo4j, resolved from env vars or the shared
    credentials file -- never hardcoded (matches ~/.edwin/credentials/*
    convention used elsewhere in this tool). Returns None if no password is
    configured (caller then makes an unauthenticated request, which the
    surrounding try/except degrades gracefully on)."""
    import base64

    neo4j_user = os.environ.get("NEO4J_USER", "neo4j")
    neo4j_pass = os.environ.get("NEO4J_PASSWORD", "")
    if not neo4j_pass:
        neo4j_creds = Path.home() / ".edwin" / "credentials" / "neo4j" / "env"
        if neo4j_creds.exists():
            for line in neo4j_creds.read_text().splitlines():
                if line.startswith("NEO4J_PASSWORD="):
                    neo4j_pass = line.split("=", 1)[1].strip()
                    break
    if not neo4j_pass:
        return None
    return base64.b64encode(f"{neo4j_user}:{neo4j_pass}".encode()).decode()


def _neo4j_cypher(statement):
    headers = {"Content-Type": "application/json"}
    auth = _neo4j_auth_header()
    if auth:
        headers["Authorization"] = f"Basic {auth}"
    req = Request(
        f"{NEO4J_URL}/db/neo4j/tx/commit",
        data=json.dumps({"statements": [{"statement": statement}]}).encode(),
        headers=headers,
    )
    with urlopen(req, timeout=10) as resp:
        result = json.loads(resp.read())
    if result.get("errors"):
        raise RuntimeError(result["errors"])
    return result["results"][0]["data"]


