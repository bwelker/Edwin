def main():
    import argparse
    p = argparse.ArgumentParser(description="Edwin Systems Health Report")
    p.add_argument("--stdout", action="store_true", help="Print to stdout")
    p.add_argument("--date", help="Report date (YYYY-MM-DD)")
    args = p.parse_args()

    report_date = args.date or datetime.now(ET).strftime("%Y-%m-%d")
    report = generate_report(report_date)

    if args.stdout:
        print(report)
    else:
        # Write to briefing book
        output_dir = BRIEFING_DIR / "1. \U0001f4cb Briefs"
        output_dir.mkdir(parents=True, exist_ok=True)
        output_path = output_dir / f"Systems Report -- {report_date}.md"
        output_path.write_text(report + "\n", encoding="utf-8")
        print(f"Report written: {output_path}", file=sys.stderr)

        # Publish to Obsidian if configured
        if OBSIDIAN_VAULT:
            vault_path = OBSIDIAN_VAULT / "1. \U0001f4cb Briefs" / f"Systems Report -- {report_date}.md"
            vault_path.parent.mkdir(parents=True, exist_ok=True)
            vault_path.write_text(report + "\n", encoding="utf-8")
            print(f"Published to Obsidian: {vault_path}", file=sys.stderr)


if __name__ == "__main__":
    main()
