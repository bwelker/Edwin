def section_api_costs(admin_key, report_date):
    """API cost report for today and MTD."""
    lines = ["## API Costs"]

    if not admin_key:
        lines.append("*Admin API key not configured. Skipping cost report.*")
        return lines

    # Latest available costs (yesterday -- today's data not available until day ends)
    latest_day = report_date - timedelta(days=1)
    today = latest_day.strftime("%Y-%m-%dT00:00:00Z")
    tomorrow = report_date.strftime("%Y-%m-%dT00:00:00Z")
    data = _api_get(
        f"https://api.anthropic.com/v1/organizations/cost_report"
        f"?starting_at={today}&ending_at={tomorrow}&bucket_width=1d"
        f"&group_by%5B%5D=description",
        admin_key
    )

    if "error" in data:
        lines.append(f"*Error fetching costs: {data['error']}*")
        return lines

    # Parse today's costs
    today_total = 0
    by_model = {}
    for bucket in data.get("data", []):
        for r in bucket.get("results", []):
            amt = float(r.get("amount", "0")) / 100
            model = r.get("model", "other")
            today_total += amt
            by_model[model] = by_model.get(model, 0) + amt

    lines.append(f"\n**Latest day ({latest_day.strftime('%Y-%m-%d')}):** ${today_total:.2f}")
    if by_model:
        lines.append("")
        lines.append("| Model | Cost |")
        lines.append("|-------|------|")
        for m, c in sorted(by_model.items(), key=lambda x: -x[1]):
            if c > 0.001:
                lines.append(f"| {m or 'n/a'} | ${c:.2f} |")

    # MTD costs
    month_start = report_date.replace(day=1).strftime("%Y-%m-%dT00:00:00Z")
    mtd_data = _api_get(
        f"https://api.anthropic.com/v1/organizations/cost_report"
        f"?starting_at={month_start}&ending_at={tomorrow}&bucket_width=1d"
        f"&group_by%5B%5D=description",
        admin_key
    )

    mtd_total = 0
    mtd_by_model = {}
    for bucket in mtd_data.get("data", []):
        for r in bucket.get("results", []):
            amt = float(r.get("amount", "0")) / 100
            model = r.get("model", "other")
            mtd_total += amt
            mtd_by_model[model] = mtd_by_model.get(model, 0) + amt

    lines.append(f"\n**Month-to-date ({report_date.strftime('%B')}):** ${mtd_total:.2f}")
    if mtd_by_model:
        lines.append("")
        lines.append("| Model | MTD Cost |")
        lines.append("|-------|----------|")
        for m, c in sorted(mtd_by_model.items(), key=lambda x: -x[1]):
            if c > 0.01:
                lines.append(f"| {m or 'n/a'} | ${c:.2f} |")

    # Daily trend (last 7 days)
    week_ago = (report_date - timedelta(days=6)).strftime("%Y-%m-%dT00:00:00Z")
    trend_data = _api_get(
        f"https://api.anthropic.com/v1/organizations/cost_report"
        f"?starting_at={week_ago}&ending_at={tomorrow}&bucket_width=1d",
        admin_key
    )

    daily_costs = []
    for bucket in trend_data.get("data", []):
        day = bucket.get("starting_at", "")[:10]
        day_total = sum(float(r.get("amount", "0")) / 100 for r in bucket.get("results", []))
        daily_costs.append((day, day_total))

    if daily_costs:
        lines.append("\n**Daily trend (7 days):**")
        lines.append("")
        lines.append("| Date | Cost |")
        lines.append("|------|------|")
        for day, cost in sorted(daily_costs):
            lines.append(f"| {day} | ${cost:.2f} |")

    return lines


def section_pipeline(report_date):
    """Connector freshness check."""
    lines = ["## Pipeline Health"]

    try:
        result = subprocess.run(
            ["python3", str(TOOLS_DIR / "librarian" / "librarian"), "freshness"],
            capture_output=True, text=True, timeout=60
        )
        output = result.stdout + result.stderr
    except Exception as e:
        lines.append(f"*Librarian error: {e}*")
        return lines

    stale = []
    healthy = []
    alerts = []
    for line in output.split("\n"):
        # Extract just the connector info after the last ]
        parts = line.split("] ")
        info = parts[-1].strip() if parts else line.strip()
        if not info:
            continue
        if "[ALERT]" in line:
            alerts.append(info)
        elif "[STALE]" in line:
            stale.append(info)
        elif "[OK]" in line:
            healthy.append(info)

    lines.append("")
    for a in alerts:
        # expired staleness dismissals (librarian's dismissed-as-non-bug registry)
        lines.append(f"- **ALERT: {a}**")
    if stale:
        lines.append(f"**Stale ({len(stale)}):**")
        for s in stale:
            lines.append(f"- {s}")
    lines.append(f"\n**Healthy ({len(healthy)}):**")
    for h in healthy:
        lines.append(f"- {h}")

    lines.extend(_job_failure_streaks())
    return lines


def _job_failure_streaks():
    """Consecutive-failure streak detection over Plombery run history.

    Any scheduled job whose most recent runs are 2+ consecutive failures gets
    an ALERT line here -- streaks, not just today's reds. A single red run
    that's easy to miss can otherwise persist unnoticed for a long time.
    'cancelled' runs are transparent (they neither break nor extend a
    streak). Pipelines whose latest failure is >7 days old are excluded -- a
    retired pipeline's dead history is not a live red (the librarian skills
    watchdog owns missing-run detection)."""
    import sqlite3

    db = TOOLS_DIR / "plombery" / "plombery.db"
    lines = ["", "**Job failure streaks (2+ consecutive = investigate or triage in writing):**"]
    if not db.exists():
        lines.append("- *plombery.db not found -- streak check skipped*")
        return lines

    try:
        conn = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
        rows = conn.execute(
            "SELECT pipeline_id, status, start_time FROM ("
            "  SELECT pipeline_id, status, start_time,"
            "         ROW_NUMBER() OVER (PARTITION BY pipeline_id ORDER BY start_time DESC) rn"
            "  FROM pipeline_runs) WHERE rn <= 20 ORDER BY pipeline_id, rn"
        ).fetchall()
        conn.close()
    except Exception as e:
        lines.append(f"- **ALERT: streak check failed to read plombery.db: {e}**")
        return lines

    by_pipeline = {}
    for pid, status, start in rows:
        by_pipeline.setdefault(pid, []).append((status, start))

    week_ago = (datetime.now() - timedelta(days=7)).strftime("%Y-%m-%d %H:%M")
    streaks = []
    for pid, runs in sorted(by_pipeline.items()):
        streak = 0
        streak_start = None
        latest_fail = None
        for status, start in runs:  # newest first
            if status == "cancelled":
                continue
            if status == "failed":
                if latest_fail is None:
                    latest_fail = start
                streak += 1
                streak_start = start
            else:
                break
        if streak >= 2 and latest_fail and str(latest_fail)[:16] >= week_ago:
            streaks.append((pid, streak, streak_start, latest_fail))

    if not streaks:
        lines.append("- none")
        return lines
    for pid, streak, since, latest in streaks:
        plus = "+" if streak >= 20 else ""
        lines.append(
            f"- **ALERT: {pid} failed {streak}{plus} consecutive runs "
            f"(since {str(since)[:16]}, latest fail {str(latest)[:16]}) -- "
            f"read run_*/logs.jsonl, fix or write a triage note today**"
        )
    return lines


def section_memory_audit():
    """Bi-temporal memory validity -- one-liner from librarian memory-audit.

    EXPIRED facts (review_after in the past) get ALERT lines: they must be
    re-verified before being trusted or repeated. Conventions:
    tools/librarian/MEMORY-CONVENTIONS.md."""
    lines = ["## Memory Validity (Bi-Temporal Audit)"]

    try:
        result = subprocess.run(
            ["python3", str(TOOLS_DIR / "librarian" / "librarian"), "memory-audit"],
            capture_output=True, text=True, timeout=60
        )
        output = result.stdout + result.stderr
    except Exception as e:
        lines.append(f"*Librarian error: {e}*")
        return lines

    summary = None
    expired_lines = []
    for line in output.split("\n"):
        parts = line.split("] ")
        info = parts[-1].strip() if parts else line.strip()
        if "memory-audit:" in line:
            summary = info
        elif "[EXPIRED]" in line:
            expired_lines.append(info)

    lines.append("")
    lines.append(f"- {summary or '*memory-audit produced no summary line*'}")
    for e in expired_lines:
        lines.append(f"- **ALERT: {e} -- nightwatch drift re-verification target**")
    return lines


def section_commitments():
    """Commitment aging one-liner from commitment-chaser (if installed).

    Full detail lives wherever your commitment-chaser pipeline publishes it
    (e.g. an "Action Tracker" doc); this just embeds the bucket counts. If
    tools/commitment-chaser isn't present in this deployment, this degrades
    to a one-line notice rather than failing the report.
    """
    lines = ["## Commitment Aging"]

    chaser = TOOLS_DIR / "commitment-chaser" / "commitment-chaser"
    if not chaser.exists():
        lines.append("")
        lines.append("- *commitment-chaser not installed -- skipping*")
        return lines

    try:
        result = subprocess.run(
            ["python3", str(chaser), "status"],
            capture_output=True, text=True, timeout=60
        )
        summary = (result.stdout or "").strip()
        if result.returncode != 0 or not summary:
            summary = f"*commitment-chaser status failed: {(result.stderr or '').strip()[:200]}*"
    except Exception as e:
        summary = f"*commitment-chaser error: {e}*"

    lines.append("")
    lines.append(f"- {summary}")
    return lines


def section_qdrant():
    """Qdrant vector store health."""
    lines = ["## Vector Store (Qdrant)"]

    data = _qdrant_get(f"/collections/{QDRANT_COLLECTION}")
    if not data:
        lines.append(f"*Qdrant not responding at {QDRANT_URL}*")
        return lines

    result = data.get("result", {})
    points = result.get("points_count", 0)
    status = result.get("status", "unknown")
    vectors = result.get("vectors_count", 0)
    segments = result.get("segments_count", 0)

    lines.append("")
    lines.append(f"| Metric | Value |")
    lines.append(f"|--------|-------|")
    lines.append(f"| Collection | {QDRANT_COLLECTION} |")
    lines.append(f"| Status | {status} |")
    lines.append(f"| Points | {points:,} |")
    lines.append(f"| Vectors | {vectors:,} |")
    lines.append(f"| Segments | {segments} |")

    # Context coverage from indexer state
    state_file = TOOLS_DIR / "indexer" / ".index-state.json"
    if state_file.exists():
        try:
            state = json.loads(state_file.read_text())
            files = state.get("files", {})
            total = len(files)
            context_done = sum(1 for v in files.values() if v.get("context_done"))
            total_chunks = sum(v.get("chunks", 0) for v in files.values())
            last_run = state.get("last_run", "unknown")

            lines.append("")
            lines.append("**Indexer:**")
            lines.append(f"- Files tracked: {total:,}")
            lines.append(f"- Total chunks: {total_chunks:,}")
            lines.append(f"- Context prefixed: {context_done:,} / {total:,} ({100*context_done/total:.1f}%)" if total else "- Context: n/a")
            lines.append(f"- Last run: {last_run}")

            # Per-source context breakdown
            source_ctx = {}
            for k, v in files.items():
                # Determine source from path
                parts = k.split("/")
                src = parts[0] if parts else "unknown"
                source_ctx.setdefault(src, {"total": 0, "done": 0})
                source_ctx[src]["total"] += 1
                if v.get("context_done"):
                    source_ctx[src]["done"] += 1

            if source_ctx:
                lines.append("")
                lines.append("**Context by source:**")
                lines.append("")
                lines.append("| Source | Files | Context Done | % |")
                lines.append("|--------|-------|-------------|---|")
                for src in sorted(source_ctx.keys()):
                    s = source_ctx[src]
                    pct = 100 * s["done"] / s["total"] if s["total"] else 0
                    lines.append(f"| {src} | {s['total']} | {s['done']} | {pct:.0f}% |")

        except (json.JSONDecodeError, IOError):
            lines.append("*Indexer state file unreadable*")

    return lines


EVAL_HISTORY_FILE = TOOLS_DIR / "librarian" / ".eval-history.jsonl"


def section_retrieval_eval():
    """Retrieval-quality eval (latest run from librarian's eval history).

    Run `librarian eval` on whatever schedule fits (e.g. weekly) -- this
    section just surfaces the latest aggregate + any regression ALERTs.
    """
    lines = ["## Retrieval Quality (Eval)"]

    if not EVAL_HISTORY_FILE.exists():
        lines.append("")
        lines.append("*No eval history yet -- run `librarian eval` to baseline.*")
        return lines

    try:
        raw = [l for l in EVAL_HISTORY_FILE.read_text().splitlines() if l.strip()]
        last = json.loads(raw[-1])
    except (json.JSONDecodeError, IndexError, IOError) as e:
        lines.append("")
        lines.append(f"*Eval history unreadable: {e}*")
        return lines

    lines.append("")
    lines.append(f"- Last run: {last.get('ts', 'unknown')} ({len(raw)} runs in history)")
    lines.append(f"- hit@3: **{last['hit3']}/{last['positives']}**  |  "
                 f"hit@8: **{last['hit8']}/{last['positives']}**  |  "
                 f"negative probes: {last['negatives_passed']}/{last['negatives']}")
    lines.append(f"- Latency p50: {last.get('latency_p50_ms', 'n/a')} ms  |  "
                 f"search mode: {', '.join(last.get('search_modes', []))}")

    misses = [q["id"] for q in last.get("queries", [])
              if not (q.get("negative_pass") if q.get("negative") else q.get("pass8"))]
    if misses:
        lines.append(f"- Failing queries: {', '.join(misses)}")

    for alert in last.get("alerts", []):
        lines.append(f"- **{alert}**")

    return lines


KG_STATE_FILE = Path(__file__).resolve().parent / ".kg-state.json"


def section_neo4j():
    """Neo4j knowledge graph health (curated entity/relationship graph, BM25 fulltext search)."""
    lines = ["## Knowledge Graph (Neo4j)"]

    if not _check_service(f"{NEO4J_URL}"):
        lines.append("")
        lines.append(f"- **ALERT: Neo4j not responding at {NEO4J_URL} -- kg_* tools are down**")
        return lines

    lines.append("")
    lines.append("- Status: **online**")

    try:
        entities = _neo4j_cypher("MATCH (n:Entity) RETURN count(n)")[0]["row"][0]
        rels = _neo4j_cypher("MATCH ()-[r]->() RETURN count(r)")[0]["row"][0]
        label_rows = _neo4j_cypher(
            "MATCH (n) UNWIND labels(n) AS l WITH l, count(*) AS c "
            "WHERE l <> 'Entity' RETURN l, c ORDER BY c DESC"
        )
        lines.append(f"- Entities: {entities:,}")
        lines.append(f"- Relationships: {rels:,}")
        if label_rows:
            breakdown = ", ".join(f"{r['row'][0]} {r['row'][1]}" for r in label_rows)
            lines.append(f"- By label: {breakdown}")

        # Provenance coverage: every edge should carry source_ref
        prov = _neo4j_cypher(
            "MATCH ()-[r]->() RETURN count(r), count(r.source_ref), count(r.invalid_at)"
        )[0]["row"]
        total_edges, with_ref, invalidated = prov
        missing_ref = total_edges - with_ref
        prov_line = f"- Provenance: {with_ref:,}/{total_edges:,} edges carry source_ref"
        if missing_ref:
            prov_line += f" -- **{missing_ref:,} missing (writes bypassing kg_add_fact?)**"
        lines.append(prov_line)
        lines.append(f"- Invalidated edges retained (superseded/corrected, never deleted): {invalidated:,}")

        # Drop detection: alert if entity count fell >20% since last run
        prev = None
        if KG_STATE_FILE.exists():
            try:
                prev = json.loads(KG_STATE_FILE.read_text()).get("entity_count")
            except (json.JSONDecodeError, IOError):
                prev = None
        if prev and entities < prev * 0.8:
            lines.append(
                f"- **ALERT: entity count dropped {prev:,} -> {entities:,} "
                f"({100 * (prev - entities) / prev:.0f}% loss) since last report -- investigate**"
            )
        KG_STATE_FILE.write_text(json.dumps({
            "entity_count": entities,
            "relationship_count": rels,
            "checked_at": datetime.now(ET).isoformat(),
        }) + "\n")
    except Exception as e:
        lines.append(f"- **ALERT: Neo4j reachable but stats query failed: {e}**")

    # Pending entity merges (ambiguous kg_add_entity candidates awaiting review)
    pending_file = PROJECT_DIR / "data" / "kg" / "pending-merges.jsonl"
    entries = []
    if pending_file.exists():
        for line in pending_file.read_text().splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    if entries:
        lines.append(f"- **Pending entity merges: {len(entries)} awaiting review** (data/kg/pending-merges.jsonl)")
        for e in entries:
            lines.append(
                f"  - {e.get('candidate_name')!r} vs existing {e.get('existing_name')!r} "
                f"(similarity {e.get('similarity_signal')}, {e.get('date')}, src {e.get('source_ref')})"
            )
        lines.append(
            "  - To resolve: merge or create by hand (kg_write/kg_add_entity), "
            "then move the line to data/kg/pending-merges-resolved.jsonl"
        )
    else:
        lines.append("- Pending entity merges: 0")

    return lines


def section_infrastructure():
    """Docker and Ollama status."""
    lines = ["## Infrastructure"]

    # Docker
    try:
        result = subprocess.run(
            ["docker", "ps", "--format", "{{.Names}}: {{.Status}}"],
            capture_output=True, text=True, timeout=10
        )
        if result.stdout.strip():
            lines.append("")
            lines.append("**Docker:**")
            for line in result.stdout.strip().split("\n"):
                lines.append(f"- {line}")
    except Exception:
        lines.append("- Docker: unavailable")

    # Ollama
    lines.append("")
    lines.append("**Ollama:**")
    if _check_service(f"{OLLAMA_URL}/api/tags"):
        try:
            with urlopen(f"{OLLAMA_URL}/api/tags", timeout=5) as resp:
                models = json.loads(resp.read()).get("models", [])
                for m in models:
                    size_gb = m.get("size", 0) / 1e9
                    lines.append(f"- {m['name']}: {size_gb:.1f} GB")
        except Exception:
            lines.append("- Online (details unavailable)")
    else:
        lines.append("- **OFFLINE**")

    return lines


# -- Main ---------------------------------------------------------------------

def generate_report(report_date=None):
    if report_date is None:
        report_date = datetime.now(ET).date()
    elif isinstance(report_date, str):
        report_date = datetime.strptime(report_date, "%Y-%m-%d").date()

    admin_key = _load_admin_key()

    lines = [
        "---",
        f"date: {report_date}",
        "type: systems-report",
        "---",
        "",
        f"# Edwin Systems Report -- {report_date}",
        f"*Generated {datetime.now(ET).strftime('%Y-%m-%d %I:%M %p ET')}*",
        "",
    ]

    lines.extend(section_api_costs(admin_key, datetime.combine(report_date, datetime.min.time())))
    lines.append("")
    lines.extend(section_pipeline(report_date))
