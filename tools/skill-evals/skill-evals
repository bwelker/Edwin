# --- target resolution -----------------------------------------------------------

def resolve_artifact(suite, override=None):
    if override:
        pth = Path(override).expanduser()
        return pth if pth.exists() else pth  # let file_exists fail on it
    candidates = []
    for glob in suite.get("artifact_globs", []):
        candidates.extend(EDWIN_HOME.glob(glob))
    if not candidates:
        return None
    return max(candidates, key=lambda p: p.stat().st_mtime)


def resolve_report(skill, override=None):
    if override:
        return Path(override).expanduser()
    rdir = REPORTS_DIR / skill
    if not rdir.is_dir():
        return None
    files = sorted(rdir.glob("*"), key=lambda p: p.stat().st_mtime)
    return files[-1] if files else None


def run_suite(skill, suite, artifact_override=None, report_override=None,
              file_overrides=None, log=print):
    """Run every check in a suite. Returns list of result rows."""
    file_overrides = file_overrides or {}
    artifact = resolve_artifact(suite, artifact_override)
    report = resolve_report(skill, report_override)
    rows = []

    for spec in suite.get("checks", []):
        name = spec["name"]
        check_id = spec["check"]
        target = spec.get("target", "artifact")
        params = dict(spec.get("params", {}))
        fn = REGISTRY.get(check_id)
        if fn is None:
            rows.append({"skill": skill, "name": name, "check": check_id,
                         "status": "FAIL", "detail": f"unknown check id {check_id}"})
            continue

        content, path, skip_reason = None, None, None
        if target == "artifact":
            path = artifact
            if path is None or not Path(path).exists():
                if check_id == "file_exists":
                    pass  # let it fail properly
                else:
                    skip_reason = "no artifact resolved"
            else:
                content = read_text(path)
        elif target == "report":
            path = report
            if path is None or not Path(path).exists():
                skip_reason = "no completion report captured"
            else:
                content = read_text(path)
        elif target == "report_artifact":
            # artifact claimed by the report -- default-suite style checks
            if report is None or not Path(report).exists():
                skip_reason = "no completion report captured"
            else:
                apath, is_none = _report_artifact_path(read_text(report))
                if is_none:
                    skip_reason = "report claims no artifact (allowed)"
                elif apath is None or not apath.exists():
                    skip_reason = "report artifact unresolvable (report_artifact_exists covers this)"
                else:
                    path = apath
                    content = read_text(apath)
        elif target == "path":
            raw = params.get("path", "")
            raw = file_overrides.get(raw, raw)
            path = Path(raw) if Path(raw).is_absolute() else EDWIN_HOME / raw
            if not path.exists():
                if check_id == "file_exists":
                    pass
                else:
                    skip_reason = f"path missing: {path}"
            else:
                content = read_text(path)
        else:
            skip_reason = f"unknown target {target}"

        if skip_reason:
            rows.append({"skill": skill, "name": name, "check": check_id,
                         "status": "SKIP", "detail": skip_reason})
            continue
        try:
            ok, detail = fn(content or "", path, params)
        except Exception as e:  # a crashing check is a failing check
            ok, detail = False, f"check crashed: {e}"
        rows.append({"skill": skill, "name": name, "check": check_id,
                     "status": "PASS" if ok else "FAIL", "detail": detail})

    for r in rows:
        log(f"  [{r['status']:4}] {skill}:{r['name']:32} {r['detail']}")
    return rows


# --- history + regression (librarian conventions) -----------------------------------

def load_history():
    if not HISTORY_FILE.exists():
        return []
    out = []
    for line in HISTORY_FILE.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            out.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return out


def detect_regressions(history, current_rows):
    """Librarian rule: a check that passed in some earlier run and has now
    failed 2 consecutive runs (previous run containing it + this one) -> ALERT."""
    alerts = []
    ever_passed = set()
    for entry in history:
        for r in entry.get("results", []):
            if r["status"] == "PASS":
                ever_passed.add(f"{r['skill']}:{r['name']}")

    def last_status(key):
        for entry in reversed(history):
            for r in entry.get("results", []):
                if f"{r['skill']}:{r['name']}" == key:
                    return r["status"]
        return None

    for r in current_rows:
        if r["status"] != "FAIL":
            continue
        key = f"{r['skill']}:{r['name']}"
        if key in ever_passed and last_status(key) == "FAIL":
            alerts.append(f"ALERT: previously-passing check '{key}' has failed 2 consecutive runs")
    return alerts


def append_history(command, rows, alerts):
    entry = {
        "ts": datetime.now().astimezone().isoformat(timespec="seconds"),
        "command": command,
        "pass": sum(1 for r in rows if r["status"] == "PASS"),
        "fail": sum(1 for r in rows if r["status"] == "FAIL"),
        "skip": sum(1 for r in rows if r["status"] == "SKIP"),
        "alerts": alerts,
        "results": rows,
    }
    with HISTORY_FILE.open("a") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")
    return entry


# --- suites ------------------------------------------------------------------------

def load_suite(skill):
    p = SUITES_DIR / f"{skill}.json"
    if not p.exists():
        return None
    return json.loads(p.read_text())


def default_suite(skill):
    """The thin suite every skill gets automatically: completion report parses,
    STATUS valid, ARTIFACT exists if claimed, no em dashes / truncation markers
    in the claimed artifact. All report-driven; SKIPs when no report captured."""
    return {
        "skill": skill,
        "checks": [
            {"name": "report-parses", "check": "report_parses", "target": "report",
             "params": {"skill": skill, "required_fields": ["STATUS"]}},
            {"name": "report-status-valid", "check": "report_field_valid", "target": "report",
             "params": {"field": "STATUS", "allowed": ["success", "partial", "error"]}},
            {"name": "report-artifact-exists", "check": "report_artifact_exists", "target": "report"},
            {"name": "artifact-no-em-dashes", "check": "no_em_dashes", "target": "report_artifact"},
            {"name": "artifact-no-truncation", "check": "no_truncation_markers", "target": "report_artifact"},
        ],
    }


def skills_from_index():
    """Skill names = first column of the docs/SKILLS.md table."""
    names = []
    if not SKILLS_INDEX.exists():
        return names
    for line in SKILLS_INDEX.read_text().splitlines():
        m = re.match(r"^\|\s*([a-z0-9][a-z0-9-]+)\s*\|", line)
        if m and m.group(1) not in ("skill",):
            names.append(m.group(1))
    return names


# --- fixtures ---------------------------------------------------------------------

def expand_placeholders(glob):
    now = datetime.now()
    y = now - timedelta(days=1)
    subs = {
        "{today}": now.strftime("%Y-%m-%d"),
        "{yesterday}": y.strftime("%Y-%m-%d"),
        "{month}": now.strftime("%Y-%m"),
        "{prev_month}": (now.replace(day=1) - timedelta(days=1)).strftime("%Y-%m"),
    }
    for k, v in subs.items():
        glob = glob.replace(k, v)
    return glob


def freeze_fixtures(skill, log=print):
    suite = load_suite(skill)
    if suite is None or not suite.get("inputs"):
        log(f"No suite (or no 'inputs' surface) for {skill} -- nothing to freeze.")
        return 1
    date = datetime.now().strftime("%Y-%m-%d")
    dest_root = FIXTURES_DIR / skill / date
    tree = dest_root / "tree"
    tree.mkdir(parents=True, exist_ok=True)

    manifest = {"skill": skill, "frozen_at": datetime.now().astimezone().isoformat(timespec="seconds"),
                "total_cap_bytes": FIXTURE_TOTAL_CAP, "entries": [], "total_bytes": 0,
                "cap_reached": False}
    total = 0

    for spec in suite["inputs"]:
        raw_glob = spec["glob"]
        glob = expand_placeholders(raw_glob)
        newest = spec.get("newest", FIXTURE_NEWEST_DEFAULT)
        file_cap = spec.get("file_cap_bytes", FIXTURE_FILE_CAP)
        matches = [p for p in EDWIN_HOME.glob(glob) if p.is_file()]
        matches.sort(key=lambda p: p.stat().st_mtime, reverse=True)
        picked = matches[:newest]
        entry = {"glob": raw_glob, "resolved_glob": glob, "files_total": len(matches),
                 "files_copied": 0, "bytes": 0, "sampled": len(matches) > len(picked),
                 "skipped_oversize": [], "skipped_cap": 0}
        for src in picked:
            size = src.stat().st_size
            if size > file_cap:
                entry["skipped_oversize"].append({"path": str(src.relative_to(EDWIN_HOME)), "bytes": size})
                continue
            if total + size > FIXTURE_TOTAL_CAP:
                entry["skipped_cap"] += 1
                manifest["cap_reached"] = True
                continue
            rel = src.relative_to(EDWIN_HOME)
            dst = tree / rel
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dst)
            total += size
            entry["files_copied"] += 1
            entry["bytes"] += size
        manifest["entries"].append(entry)
        log(f"  {glob}: {entry['files_copied']}/{entry['files_total']} files, "
            f"{entry['bytes'] / 1024:.0f} KB"
            + (" (sampled)" if entry["sampled"] else "")
            + (f", {len(entry['skipped_oversize'])} oversize skipped" if entry["skipped_oversize"] else "")
            + (f", {entry['skipped_cap']} cap-skipped" if entry["skipped_cap"] else ""))

    manifest["total_bytes"] = total
    (dest_root / "manifest.json").write_text(json.dumps(manifest, indent=2, ensure_ascii=False))
    log(f"Frozen {skill} inputs -> {dest_root}  ({total / (1024 * 1024):.1f} MB)")
    return 0


# --- commands ----------------------------------------------------------------------

def cmd_check(args):
    suite = load_suite(args.skill)
    rows = []
    if suite is not None:
        print(f"Suite: {args.skill} ({len(suite.get('checks', []))} checks)")
        rows += run_suite(args.skill, suite, args.artifact, args.report,
                          dict(o.split("=", 1) for o in args.path_override))
    print(f"Default suite: {args.skill}")
    rows += run_suite(args.skill, default_suite(args.skill), None, args.report)

    history = load_history()
    alerts = detect_regressions(history, rows)
    if args.no_history:
        entry = {"pass": sum(1 for r in rows if r["status"] == "PASS"),
                 "fail": sum(1 for r in rows if r["status"] == "FAIL"),
                 "skip": sum(1 for r in rows if r["status"] == "SKIP")}
        alerts = []  # test runs don't alert or baseline
        print(f"\n{args.skill}: {entry['pass']} pass, {entry['fail']} fail, "
              f"{entry['skip']} skip (test run, not recorded)")
        return 2 if entry["fail"] else 0
    entry = append_history(f"check {args.skill}", rows, alerts)
    print(f"\n{args.skill}: {entry['pass']} pass, {entry['fail']} fail, "
          f"{entry['skip']} skip (history: {len(history) + 1} runs)")
    for a in alerts:
        print(a)
    return 2 if (entry["fail"] or alerts) else 0


def cmd_check_all(args):
    skills = skills_from_index()
    all_rows = []
    summary = []
    for skill in skills:
        suite = load_suite(skill)
        rows = []
        if suite is not None:
            print(f"\n=== {skill} (full suite) ===")
            rows += run_suite(skill, suite)
        else:
            print(f"\n=== {skill} (default suite only) ===")
        rows += run_suite(skill, default_suite(skill))
        all_rows += rows
        summary.append((skill,
                        sum(1 for r in rows if r["status"] == "PASS"),
                        sum(1 for r in rows if r["status"] == "FAIL"),
                        sum(1 for r in rows if r["status"] == "SKIP"),
                        "full" if suite else "default"))

    # System-level suites: any suites/*.json whose stem is NOT a skill in
    # docs/SKILLS.md (e.g. suites/system.json). These carry cross-skill /
    # infrastructure checks -- the self-retro's evaluator ratchet lands
    # non-skill corrections here. Full suite only; there is no Completion
    # Report to grade, so no default suite.
    for p in sorted(SUITES_DIR.glob("*.json")):
        name = p.stem
        if name in skills:
            continue
        suite = load_suite(name)
        print(f"\n=== {name} (system-level suite) ===")
        rows = run_suite(name, suite)
        all_rows += rows
        summary.append((name,
                        sum(1 for r in rows if r["status"] == "PASS"),
                        sum(1 for r in rows if r["status"] == "FAIL"),
                        sum(1 for r in rows if r["status"] == "SKIP"),
                        "system"))

    history = load_history()
    alerts = detect_regressions(history, all_rows)
    entry = append_history("check-all", all_rows, alerts)

    print("\n" + "=" * 62)
    print(f"{'skill':28} {'suite':8} {'pass':>5} {'fail':>5} {'skip':>5}")
    print("-" * 62)
    for skill, p, f, s, kind in summary:
        print(f"{skill:28} {kind:8} {p:>5} {f:>5} {s:>5}")
    print("-" * 62)
    print(f"{'TOTAL':28} {'':8} {entry['pass']:>5} {entry['fail']:>5} {entry['skip']:>5}")
    for a in alerts:
        print(a)
    return 2 if (entry["fail"] or alerts) else 0


def cmd_fixtures(args):
    if args.action != "freeze":
        print("Only 'fixtures freeze <skill>' is supported.")
        return 1
    return freeze_fixtures(args.skill)


def cmd_list(args):
    print("Check registry:")
    for cid, doc in REGISTRY_DOC.items():
        print(f"  {cid:28} {doc}")
    print("\nFull suites:")
    for p in sorted(SUITES_DIR.glob("*.json")):
        suite = json.loads(p.read_text())
        print(f"  {p.stem:28} {len(suite.get('checks', []))} checks, "
              f"{len(suite.get('inputs', []))} input globs")
    print("\nDefault suite applies to every skill in docs/SKILLS.md:")
    print("  " + ", ".join(skills_from_index()))
    return 0


def main():
    ap = argparse.ArgumentParser(prog="skill-evals", description=__doc__.splitlines()[0])
    sub = ap.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("check", help="run one skill's suite")
    p.add_argument("skill")
    p.add_argument("--artifact", help="artifact path override (for corruption tests / replay)")
    p.add_argument("--report", help="completion report path override")
    p.add_argument("--path-override", action="append", default=[],
                   metavar="ORIG=NEW", help="override a path-target (e.g. ledger) for tests")
    p.add_argument("--no-history", action="store_true",
                   help="don't record this run (corruption tests / fixture replay)")
    p.set_defaults(fn=cmd_check)

    p = sub.add_parser("check-all", help="default suite for every skill + full suites where they exist")
    p.set_defaults(fn=cmd_check_all)

    p = sub.add_parser("fixtures", help="freeze input fixtures")
    p.add_argument("action", choices=["freeze"])
    p.add_argument("skill")
    p.set_defaults(fn=cmd_fixtures)

    p = sub.add_parser("list", help="show check registry + suites")
    p.set_defaults(fn=cmd_list)

    args = ap.parse_args()
    sys.exit(args.fn(args))


if __name__ == "__main__":
    main()
