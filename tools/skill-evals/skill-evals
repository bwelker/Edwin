SUITES_DIR = TOOL_DIR / "suites"
FIXTURES_DIR = TOOL_DIR / "fixtures"
HISTORY_FILE = TOOL_DIR / ".eval-history.jsonl"
REPORTS_DIR = EDWIN_HOME / "data" / "skill-evals" / "reports"
SKILLS_INDEX = EDWIN_HOME / "docs" / "SKILLS.md"

FIXTURE_TOTAL_CAP = 50 * 1024 * 1024   # 50MB per skill
FIXTURE_FILE_CAP = 12 * 1024 * 1024    # skip any single file bigger than this
FIXTURE_NEWEST_DEFAULT = 40            # newest-N per glob unless overridden

EM_DASH = "—"
TRUNCATION_RE = re.compile(r"\[truncated\]|\[TRUNCATED\]|\.\.\.\s*\(truncated|…\s*\(truncated")


# --- small helpers ----------------------------------------------------------------

def read_text(path):
    return Path(path).read_text(errors="replace")


def parse_frontmatter(text):
    """Minimal YAML frontmatter parser: leading --- block of `key: value` lines.
    Returns (dict, ok). Nested/complex YAML is out of scope on purpose --
    skill artifacts use flat frontmatter."""
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return {}, False
    fm = {}
    for line in lines[1:]:
        if line.strip() == "---":
            return fm, True
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        m = re.match(r"^([A-Za-z_][A-Za-z0-9_-]*):\s*(.*)$", line)
        if not m:
            return fm, False
        val = m.group(2).strip()
        # strip an inline comment ("edition: weekday  # or weekend")
        val = re.sub(r"\s+#.*$", "", val).strip().strip('"').strip("'")
        fm[m.group(1)] = val
    return fm, False  # never saw the closing ---


def parse_report(text):
    """Parse a Completion Report block: `KEY: value` lines, KEY uppercase with
    underscores. Multi-line values (lists under a field) attach to the last key."""
    fields = {}
    order = []
    current = None
    for line in text.splitlines():
        m = re.match(r"^([A-Z][A-Z0-9_]+):\s*(.*)$", line.strip())
        if m:
            current = m.group(1)
            fields[current] = m.group(2).strip()
            order.append(current)
        elif current and line.strip():
            fields[current] += "\n" + line.strip()
    return fields, order


def section_body(text, heading_pattern):
    """Return the body of the first markdown section whose heading line matches
    heading_pattern, up to the next heading of the same-or-higher level."""
    lines = text.splitlines()
    start = None
    level = None
    for i, line in enumerate(lines):
        hm = re.match(r"^(#{1,6})\s", line)
        if start is None:
            if hm and re.search(heading_pattern, line):
                start = i
                level = len(hm.group(1))
        else:
            if hm and len(hm.group(1)) <= level:
                return "\n".join(lines[start + 1:i])
    if start is None:
        return None
    return "\n".join(lines[start + 1:])


# --- check registry -----------------------------------------------------------------
# Every check: fn(content, path, params) -> (bool_pass, detail_str)
# `content` is file text for artifact/path targets, or report text for report targets.

def c_file_exists(content, path, p):
    if path is None or not Path(path).exists():
        return False, f"missing: {path}"
    if Path(path).stat().st_size == 0:
        return False, f"empty file: {path}"
    return True, str(path)


def c_file_fresh(content, path, p):
    """Target file's mtime is within params.max_age_hours. Guards system-suite
    checks against silently passing on a stale artifact (e.g. yesterday's
    Systems Report after the nightly job died)."""
    if path is None or not Path(path).exists():
        return False, f"missing: {path}"
    age_h = (datetime.now().timestamp() - Path(path).stat().st_mtime) / 3600
    return age_h <= p["max_age_hours"], f"{age_h:.1f}h old (max {p['max_age_hours']}h)"


def c_min_lines(content, path, p):
    n = len(content.splitlines())
    return n >= p["min"], f"{n} lines (min {p['min']})"


def c_max_lines(content, path, p):
    n = len(content.splitlines())
    return n <= p["max"], f"{n} lines (max {p['max']})"


def c_frontmatter_parses(content, path, p):
    fm, ok = parse_frontmatter(content)
    return ok, f"{len(fm)} fields" if ok else "no valid --- frontmatter block"


def c_frontmatter_fields(content, path, p):
    fm, ok = parse_frontmatter(content)
    if not ok:
        return False, "frontmatter did not parse"
    missing = [k for k in p.get("required", []) if k not in fm]
    if missing:
        return False, f"missing fields: {missing}"
    for k, rex in p.get("value_patterns", {}).items():
        if k in fm and not re.fullmatch(rex, fm[k]):
            return False, f"{k}={fm[k]!r} fails /{rex}/"
    return True, "all required fields present + valid"


def c_date_matches_filename(content, path, p):
    fm, ok = parse_frontmatter(content)
    if not ok or "date" not in fm:
        return False, "no parseable date in frontmatter"
    if path is None:
        return False, "no file path to compare"
    fname = Path(path).name
    if fm["date"] in fname:
        return True, f"{fm['date']} in {fname}"
    return False, f"frontmatter date {fm['date']} not in filename {fname}"


def c_section_present(content, path, p):
    if re.search(p["pattern"], content, re.MULTILINE):
        return True, f"/{p['pattern']}/ found"
    return False, f"/{p['pattern']}/ not found"


def c_sections_in_order(content, path, p):
    pos = -1
    for pat in p["patterns"]:
        m = re.search(pat, content, re.MULTILINE)
        if not m:
            return False, f"/{pat}/ not found"
        if m.start() < pos:
            return False, f"/{pat}/ appears out of order"
        pos = m.start()
    return True, f"{len(p['patterns'])} sections in order"


def c_regex_present(content, path, p):
    n = len(re.findall(p["pattern"], content, re.MULTILINE))
    need = p.get("min_count", 1)
    return n >= need, f"{n} matches of /{p['pattern']}/ (need >= {need})"


def c_regex_all(content, path, p):
    missing = [pat for pat in p["patterns"]
               if not re.search(pat, content, re.MULTILINE)]
    if missing:
        return False, f"missing: {missing[:3]}{'...' if len(missing) > 3 else ''}"
    return True, f"all {len(p['patterns'])} patterns present"


def c_regex_absent(content, path, p):
    m = re.search(p["pattern"], content, re.MULTILINE)
    if m:
        line = content[:m.start()].count("\n") + 1
        return False, f"/{p['pattern']}/ found at line {line}"
    return True, f"/{p['pattern']}/ absent"


def c_no_em_dashes(content, path, p):
    if EM_DASH in content:
        line = content[:content.index(EM_DASH)].count("\n") + 1
        return False, f"em dash (U+2014) at line {line}"
    return True, "no em dashes"


def c_no_truncation_markers(content, path, p):
    m = TRUNCATION_RE.search(content)
    if m:
        line = content[:m.start()].count("\n") + 1
        return False, f"truncation marker at line {line}"
    return True, "no truncation markers"


def c_counts_equal(content, path, p):
    a = len(re.findall(p["pattern_a"], content, re.MULTILINE))
    b = len(re.findall(p["pattern_b"], content, re.MULTILINE))
    return a == b, f"{a} vs {b} ({p.get('label', 'pattern_a vs pattern_b')})"


def c_frontmatter_count_matches(content, path, p):
    fm, ok = parse_frontmatter(content)
    if not ok or p["field"] not in fm:
        return False, f"frontmatter field {p['field']} missing"
    try:
        declared = int(fm[p["field"]])
    except ValueError:
        return False, f"{p['field']}={fm[p['field']]!r} not an integer"
    actual = len(re.findall(p["pattern"], content, re.MULTILINE))
    return declared == actual, f"frontmatter {p['field']}={declared}, counted {actual}"


def c_numbered_list_max(content, path, p):
    body = section_body(content, p["section"])
    if body is None:
        return False, f"section /{p['section']}/ not found"
    n = len(re.findall(r"^\d+\.\s", body, re.MULTILINE))
    return n <= p["max"], f"{n} numbered items in section (max {p['max']})"


def c_checkbox_states_valid(content, path, p):
    bad = re.findall(r"^\s*[-*] \[([^ xX])\]", content, re.MULTILINE)
    if bad:
        return False, f"invalid checkbox states: {sorted(set(bad))}"
    return True, "all checkbox states are [ ] or [x]"


def c_json_parses(content, path, p):
    try:
        obj = json.loads(content)
    except json.JSONDecodeError as e:
        return False, f"invalid JSON: {e}"
    missing = [k for k in p.get("required_keys", []) if k not in obj]
    if missing:
        return False, f"missing top-level keys: {missing}"
    return True, "valid JSON"


def c_jsonl_parses(content, path, p):
    for i, line in enumerate(content.splitlines(), 1):
        if not line.strip():
            continue
        try:
            json.loads(line)
        except json.JSONDecodeError as e:
            return False, f"line {i} invalid: {e}"
    return True, f"{sum(1 for l in content.splitlines() if l.strip())} lines parse"


def c_jsonl_schema_fields(content, path, p):
    required = p.get("required", [])
    enums = p.get("enums", {})
    patterns = p.get("field_patterns", {})
    for i, line in enumerate(content.splitlines(), 1):
        if not line.strip():
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            return False, f"line {i} not JSON"
        missing = [k for k in required if k not in obj]
        if missing:
            return False, f"line {i} missing {missing}"
        for k, allowed in enums.items():
            if k in obj and obj[k] not in allowed:
                return False, f"line {i}: {k}={obj[k]!r} not in {allowed}"
        for k, rex in patterns.items():
            if k in obj and not re.fullmatch(rex, str(obj[k])):
                return False, f"line {i}: {k}={obj[k]!r} fails /{rex}/"
    return True, "all lines carry required schema"


def c_report_parses(content, path, p):
    fields, _ = parse_report(content)
    if "SKILL_COMPLETE" not in fields:
        return False, "no SKILL_COMPLETE line"
    skill = p.get("skill")
    if skill and fields["SKILL_COMPLETE"].split()[0] != skill:
        return False, f"SKILL_COMPLETE={fields['SKILL_COMPLETE']!r}, expected {skill}"
    missing = [k for k in p.get("required_fields", ["STATUS"]) if k not in fields]
    if missing:
        return False, f"missing report fields: {missing}"
    return True, f"report parses ({len(fields)} fields)"


def c_report_field_valid(content, path, p):
    fields, _ = parse_report(content)
    field = p["field"]
    if field not in fields:
        return False, f"no {field} field"
    value = fields[field].splitlines()[0].strip()
    allowed = p["allowed"]
    if value in allowed:
        return True, f"{field}={value}"
    return False, f"{field}={value!r} not in {allowed}"


def _report_artifact_path(report_text):
    """Extract the ARTIFACT path from a report. Returns (path_or_None, is_none_claim)."""
    fields, _ = parse_report(report_text)
    raw = fields.get("ARTIFACT", "").splitlines()[0].strip() if fields.get("ARTIFACT") else ""
    if not raw:
        return None, False
    low = raw.lower()
    if low.startswith(("none", "n/a")):
        return None, True
    # tolerate trailing annotations like "| none (zero decisions)" leftovers
    raw = raw.split(" | ")[0].strip()
    return Path(raw.replace("~", str(Path.home()))), False


def c_report_artifact_exists(content, path, p):
    apath, is_none = _report_artifact_path(content)
    if is_none:
        return True, "ARTIFACT: none (explicitly claimed, allowed)"
    if apath is None:
        return False, "no ARTIFACT field in report"
    if apath.exists():
        return True, f"artifact exists: {apath}"
    return False, f"claimed artifact missing: {apath}"


def c_zero_requires_no_artifact(content, path, p):
    """A zero count in a report field requires the no-file rule respected
    (e.g. DECISIONS_FOUND: 0 -> ARTIFACT must be none); nonzero requires a
    real artifact."""
    fields, _ = parse_report(content)
    field = p["field"]
    if field not in fields:
        return False, f"no {field} field"
    first = fields[field].splitlines()[0].strip()
    m = re.match(r"^(\d+)", first)
    if not m:
        return False, f"{field}={first!r} does not start with a count"
    count = int(m.group(1))
    apath, is_none = _report_artifact_path(content)
    if count == 0:
        if is_none:
            return True, f"{field}=0 and ARTIFACT=none (no-file rule respected)"
        return False, f"{field}=0 but ARTIFACT={apath} (should be none)"
    if apath is not None and apath.exists():
        return True, f"{field}={count} and artifact exists"
    return False, f"{field}={count} but no existing artifact claimed"


